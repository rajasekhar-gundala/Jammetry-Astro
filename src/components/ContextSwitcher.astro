---
const { user } = Astro.props;

// Check if the user is authorized for both or just one (optional logic)
// For now, we'll show the toggle based on where they currently are
const isChat = user.app_context === 'docs-chat';
const isExtract = user.app_context === 'pdf-extract';
---

<div class="flex items-center bg-gray-950 border border-gray-800 rounded-full p-1 w-fit mb-6">
  <a 
    href="/dashboard/chat" 
    class={`px-4 py-1.5 rounded-full text-xs font-bold transition ${isChat ? 'bg-blue-600 text-white shadow-lg' : 'text-gray-500 hover:text-gray-300'}`}
  >
    Docs-Chat
  </a>
  <a 
    href="/dashboard/extract" 
    class={`px-4 py-1.5 rounded-full text-xs font-bold transition ${isExtract ? 'bg-blue-600 text-white shadow-lg' : 'text-gray-500 hover:text-gray-300'}`}
  >
    PDF-Extract
  </a>
</div>