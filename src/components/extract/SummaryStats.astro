---
const pb = Astro.locals.pb;
const user = Astro.locals.user; 

let stats = {
    totalRevenue: 0,
    validatedCount: 0,
    actionRequired: 0,
    lastSync: "Never"
};

if (user) {
    try {
        // 👇 FIX: Removed the admin authWithPassword completely.
        // We just fetch as the normal user using their session cookie!
        const records = await pb.collection('sales_data').getFullList({
            filter: `user_id = "${user.id}"`, 
            fields: 'invoice_total,validation_status,created',
            sort: '-created',
            requestKey: null
        });

        if (records.length > 0) {
            stats.totalRevenue = records.reduce((acc, r) => acc + (parseFloat(r.invoice_total) || 0), 0);
            stats.validatedCount = records.filter(r => r.validation_status?.toLowerCase() === 'valid').length;
            stats.actionRequired = records.filter(r => r.validation_status?.toLowerCase() === 'invalid').length;

            const lastEntryDate = new Date(records[0].created);
            stats.lastSync = lastEntryDate.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' }) + ' ' + lastEntryDate.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        }
    } catch (e: any) {
        if (e.status !== 0) console.error("SummaryStats Error:", e.message);
    }
}

const now = new Date();
const generatedAt = now.toLocaleDateString('en-GB', { day: '2-digit', month: 'short' }) + ' ' + now.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
---

<div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
    <div class="bg-gray-900 border border-gray-800 p-8 rounded-3xl relative overflow-hidden group hover:border-blue-500/30 transition-all duration-500">
        <div class="absolute -right-4 -top-4 w-24 h-24 bg-blue-500/5 blur-3xl rounded-full group-hover:bg-blue-500/10 transition z-0"></div>

        <div class="relative z-10">
            <div class="flex justify-between items-start mb-2">
                <p class="text-blue-500 text-[10px] font-black uppercase tracking-widest">Total Revenue</p>
                <div class="flex items-center gap-2">
                    <span class="text-[9px] text-gray-600 font-mono italic">Ref: {generatedAt}</span>
                    <button
                        id="refreshStats"
                        type="button"
                        class="text-gray-600 hover:text-blue-400 transition-all cursor-pointer p-1 -m-1 active:scale-95"
                        aria-label="Refresh Dashboard"
                    >
                        <svg id="refreshIcon" class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
                        </svg>
                    </button>
                </div>
            </div>
            <h4 class="text-4xl font-black text-white">
                <span class="text-gray-500 font-light mr-1">$</span>{stats.totalRevenue.toLocaleString(undefined, {minimumFractionDigits: 2})}
            </h4>
            <div class="mt-4 flex items-center gap-2">
                <span class="flex h-1.5 w-1.5 rounded-full bg-blue-500 shadow-[0_0_8px_rgba(59,130,246,0.5)]"></span>
                <p class="text-[9px] text-gray-500 uppercase font-bold tracking-tighter">
                    Last Entry: <span class="text-blue-400">{stats.lastSync}</span>
                </p>
            </div>
        </div>
    </div>

    <div class="bg-gray-900 border border-gray-800 p-8 rounded-3xl relative overflow-hidden group">
        <p class="text-green-500 text-[10px] font-black uppercase tracking-widest mb-2">Validated</p>
        <h4 class="text-4xl font-black text-white">{stats.validatedCount}</h4>
        <p class="mt-4 text-[9px] text-gray-500 uppercase font-bold tracking-tighter">Verified Compliant</p>
    </div>

    <div class="bg-gray-900 border border-gray-800 p-8 rounded-3xl relative overflow-hidden group">
        <p class="text-red-500 text-[10px] font-black uppercase tracking-widest mb-2">Action Required</p>
        <h4 class="text-4xl font-black text-white">{stats.actionRequired}</h4>
        <p class="mt-4 text-[9px] text-gray-500 uppercase font-bold tracking-tighter">Missing Tax Data</p>
    </div>
</div>

<script>
    const setupRefresh = () => {
        const btn = document.getElementById('refreshStats');
        const icon = document.getElementById('refreshIcon');

        btn?.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            icon?.classList.add('animate-spin');
            btn.style.pointerEvents = 'none';
            btn.style.opacity = '0.5';
            setTimeout(() => window.location.reload(), 400);
        });
    };
    setupRefresh();
</script>