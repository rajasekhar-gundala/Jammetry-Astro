---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import SummaryStats from '../../components/extract/SummaryStats.astro';
import DataTable from '../../components/extract/DataTable.astro';
import ContextSwitcher from '../../components/ContextSwitcher.astro';
import SEO from '../../components/SEO.astro';

const user = Astro.locals.user;
// 1. Capture the token on the server side
const token = Astro.locals.pb.authStore.token;
---

<DashboardLayout title="Enterprise Sales Extraction">
    <ContextSwitcher user={user} />

    <div class="flex justify-between items-center mb-8">
        <div>
            <h1 class="text-3xl font-bold text-white tracking-tight">Invoice Analytics</h1>
            <p class="text-gray-400 text-sm mt-1">Real-time AI Document Extraction</p>
        </div>

        <div class="flex items-center gap-6">
            <form action="/logout" method="GET">
                <button type="submit" class="text-gray-500 hover:text-red-400 text-sm font-medium transition flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path></svg>
                    Log Out
                </button>
            </form>

            <a href="/profile" class="text-gray-400 hover:text-white transition flex items-center gap-2 text-sm font-medium">
                Profile &rarr;
            </a>
        </div>
    </div>

    <SummaryStats />

    <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 my-8 shadow-xl">
        <div class="flex flex-col md:flex-row items-center gap-6">
            <div class="flex-1 w-full">
                <label class="block text-sm font-medium text-gray-400 mb-2">Upload Sales Invoices (PDF)</label>
                <input
                    type="file"
                    id="pdfs"
                    multiple
                    accept=".pdf"
                    class="w-full text-sm text-gray-400 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-blue-600 file:text-white hover:file:bg-blue-500 cursor-pointer"
                />
            </div>
            <button
                id="upBtn"
                class="w-full md:w-auto bg-white hover:bg-gray-100 text-gray-950 font-bold py-3 px-8 rounded-xl transition shadow-lg disabled:opacity-50"
            >
                Process Invoices
            </button>
        </div>

        <div class="hidden mt-8 pt-6 border-t border-gray-800" id="statusContainer">
            <div class="flex justify-between text-xs mb-2">
                <span id="progress-text" class="text-blue-400 font-medium uppercase tracking-wider">Extraction in Progress</span>
                <span id="progress-percent" class="text-gray-500">0%</span>
            </div>
            <div class="h-1.5 bg-gray-800 rounded-full overflow-hidden mb-6">
                <div id="fill" class="h-full bg-blue-500 transition-all duration-300 shadow-[0_0_10px_rgba(59,130,246,0.5)]" style="width: 0%"></div>
            </div>

            <div id="checklist" class="space-y-2 max-h-40 overflow-y-auto pr-2 custom-scrollbar">
            </div>
        </div>
    </div>

    <DataTable />

    <!-- 👇 NEW: Custom Limit Reached Modal -->
    <div id="limit-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-gray-950/80 backdrop-blur-sm transition-opacity">
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 w-full max-w-md shadow-2xl transform scale-100 transition-transform relative">
            <button id="close-modal-x" class="absolute top-4 right-4 text-gray-500 hover:text-white transition">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
            </button>

            <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 rounded-full bg-amber-500/10 flex items-center justify-center text-amber-500 shrink-0">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>
                </div>
                <div>
                    <h3 class="text-xl font-bold text-white tracking-tight">Action Required</h3>
                </div>
            </div>
            
            <p class="text-gray-400 mb-8 text-sm pl-16 leading-relaxed" id="limit-modal-text">Daily limit reached.</p>
            
            <div class="flex justify-end gap-3 pt-4 border-t border-gray-800/50">
                <button id="close-modal-btn" class="px-5 py-2.5 rounded-xl text-sm font-medium text-gray-400 hover:text-white hover:bg-gray-800 transition">Cancel</button>
                <a href="/profile" class="px-5 py-2.5 rounded-xl text-sm font-medium bg-blue-600 hover:bg-blue-500 text-white transition shadow-[0_0_15px_rgba(37,99,235,0.4)] flex items-center gap-2">
                    Upgrade to Pro
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                </a>
            </div>
        </div>
    </div>

    <style>
        .custom-scrollbar::-webkit-scrollbar { width: 4px; }
        .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
        .custom-scrollbar::-webkit-scrollbar-thumb { background: #374151; border-radius: 10px; }
    </style>

    <script is:inline define:vars={{ token }}>
    const btn = document.getElementById('upBtn');
    const fileInput = document.getElementById('pdfs');
    const statusContainer = document.getElementById('statusContainer');
    const fill = document.getElementById('fill');
    const percentText = document.getElementById('progress-percent');
    const checklist = document.getElementById('checklist');

    // 👇 Modal Element Selectors
    const limitModal = document.getElementById('limit-modal');
    const limitModalText = document.getElementById('limit-modal-text');
    
    // Modal Close Logic
    const closeLimitModal = () => {
        limitModal.classList.add('hidden');
        limitModal.classList.remove('flex');
    };
    document.getElementById('close-modal-x')?.addEventListener('click', closeLimitModal);
    document.getElementById('close-modal-btn')?.addEventListener('click', closeLimitModal);

    btn.addEventListener('click', async () => {
        const files = fileInput.files;
        if (!files || files.length === 0) return alert("Please select files first.");

        if (!token) {
            console.error("Infrastructure Error: No token available in script context.");
            return alert("Session expired. Please log in again.");
        }

        btn.disabled = true;
        btn.innerText = "Processing...";
        statusContainer.classList.remove('hidden');
        checklist.innerHTML = '';

        for (let i = 0; i < files.length; i++) {
            const currentFile = files[i];

            const item = document.createElement('div');
            item.className = "flex items-center gap-3 text-sm text-gray-500 animate-pulse";
            item.id = `file-${i}`;
            item.innerHTML = `
                <svg class="w-4 h-4 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor"><path d="M12 2v4m0 12v4M4.93 4.93l2.83 2.83m8.48 8.48l2.83 2.83M2 12h4m12 0h4M4.93 19.07l2.83-2.83m8.48-8.48l2.83-2.83" stroke-width="2" stroke-linecap="round"/></svg>
                <span>Extracting: ${currentFile.name}</span>
            `;
            checklist.prepend(item);

            const fd = new FormData();
            fd.append('file', currentFile);

            let simProgress = 0;
            const simInterval = setInterval(() => {
                if (simProgress < 90) {
                    simProgress += Math.random() * 3;
                    fill.style.width = `${Math.min(simProgress, 90)}%`;
                    percentText.innerText = `Analyzing (${Math.round(simProgress)}%)`;
                }
            }, 1000);

            try {
                const response = await fetch('https://api.rajasekhar.digital/api/extract', {
                    method: 'POST',
                    body: fd,
                    headers: {
                        'Authorization': `Bearer ${token}`
                    }
                });

                clearInterval(simInterval);

                if (response.status === 403) {
                    const errorData = await response.json();

                    item.classList.remove('text-gray-500', 'animate-pulse');
                    item.classList.add('text-amber-500');
                    item.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" stroke-width="2"/></svg><span>Limit Reached</span>`;

                    // 👇 THE FIX: Trigger the Custom UI Modal instead of alert()
                    limitModalText.innerText = errorData.error || "Daily limit reached for free tier. Please upgrade to Pro.";
                    limitModal.classList.remove('hidden');
                    limitModal.classList.add('flex');

                    break;
                }

                if (response.ok) {
                    item.classList.remove('text-gray-500', 'animate-pulse');
                    item.classList.add('text-green-400');
                    item.innerHTML = `
                        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                        <span>Done: ${currentFile.name}</span>
                    `;
                } else {
                    throw new Error("Backend processing failed");
                }
            } catch (err) {
                item.classList.remove('animate-pulse');
                item.classList.add('text-red-400');
                item.innerHTML = `<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M6 18L18 6M6 6l12 12" stroke-width="2"/></svg><span>Failed: ${currentFile.name}</span>`;
            }

            const actualProgress = Math.round(((i + 1) / files.length) * 100);
            fill.style.width = `${actualProgress}%`;
            percentText.innerText = `${actualProgress}%`;
        }

        btn.disabled = false;
        btn.innerText = "Process Invoices";

        // Only reload if the modal isn't currently showing (so they have time to read it)
        if (limitModal.classList.contains('hidden')) {
            setTimeout(() => {
                window.location.reload();
            }, 2000);
        }
    });
    </script>
</DashboardLayout>