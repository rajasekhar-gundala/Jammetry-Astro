---
export const prerender = false;
import SEO from '../../../components/SEO.astro';

let errorMessage = "";

console.log(">>> Admin Login Route Accessed. Method:", Astro.request.method);

if (Astro.request.method === "POST") {
    try {
        const data = await Astro.request.formData();
        const email = data.get("email") as string;
        const password = data.get("password") as string;

        console.log(">>> Credentials received for:", email);

        // 1. Authenticate against the Superusers collection
        await Astro.locals.pb
            .collection('_superusers')
            .authWithPassword(email, password);

        console.log(">>> Auth Success! Exporting Session...");

        // 2. Export the cookie with dynamic security
        // If testing on HTTP (local/IP), secure MUST be false or the browser deletes it.
        const isProd = process.env.NODE_ENV === 'production';
        const cookie = Astro.locals.pb.authStore.exportToCookie({
            path: '/',
            secure: isProd, 
            httpOnly: false, 
            sameSite: 'Lax',
            maxAge: 60 * 60 * 24 * 7
        });

        // 3. Sync local store and set header
        Astro.locals.pb.authStore.loadFromCookie(cookie);
        Astro.response.headers.append('set-cookie', cookie);

        console.log(">>> Redirecting to Command Center...");
        return Astro.redirect("/admin");

    } catch (error: any) {
        console.error(">>> !!! ADMIN AUTH FAIL:", error.status, error.message);
        errorMessage = "Invalid Superuser Credentials.";
    }
}
---

<html lang="en">
  <head>
    <SEO title="Admin Login | Command Center" description="Secure access for platform administrators." />
  </head>
  <body class="bg-black text-gray-100 font-sans antialiased min-h-screen flex items-center justify-center relative overflow-hidden">

    <div class="absolute top-0 left-0 w-full h-full opacity-20 pointer-events-none">
        <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-blue-500/20 blur-[120px] rounded-full"></div>
    </div>

    <main class="w-full max-w-md px-6 relative z-10">
      <div class="text-center mb-10">
        <div class="inline-block p-4 rounded-2xl bg-gray-900 border border-gray-800 mb-4 shadow-2xl">
            <svg class="w-10 h-10 text-blue-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path>
            </svg>
        </div>
        <h1 class="text-2xl font-black uppercase tracking-tighter text-white">Command Center</h1>
        <p class="text-gray-500 text-sm font-mono mt-1">Admin Authentication Required</p>
      </div>

      <div class="bg-gray-900/50 backdrop-blur-xl border border-gray-800 rounded-3xl p-8 shadow-3xl">
        <form method="POST" class="space-y-6">
          {errorMessage && (
            <div class="bg-red-500/10 border border-red-500/50 text-red-400 p-4 rounded-xl text-xs font-mono text-center">
              {errorMessage}
            </div>
          )}

          <div>
            <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Internal Email</label>
            <input
              type="email"
              name="email"
              required
              class="w-full bg-black border border-gray-800 rounded-xl px-4 py-3 text-white focus:border-blue-500 outline-none transition font-mono text-sm"
              placeholder="admin@rajasekhar.digital"
            />
          </div>

          <div>
            <label class="block text-[10px] font-bold text-gray-500 uppercase tracking-widest mb-2">Access Key</label>
            <input
              type="password"
              name="password"
              required
              class="w-full bg-black border border-gray-800 rounded-xl px-4 py-3 text-white focus:border-blue-500 outline-none transition font-mono text-sm" 
              placeholder="••••••••"
            />
          </div>

          <button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-4 rounded-xl transition-all shadow-lg shadow-blue-600/20 active:scale-95 uppercase text-xs tracking-widest">
            Initialize Session
          </button>
        </form>
      </div>

      <div class="mt-8 text-center">
        <a href="/" class="text-gray-600 hover:text-gray-400 text-xs transition">&larr; Return to Public Site</a>
      </div>
    </main>
  </body>
</html>