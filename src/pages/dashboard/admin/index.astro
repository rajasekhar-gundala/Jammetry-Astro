---
import DashboardLayout from '../../layouts/DashboardLayout.astro';

const pb = Astro.locals.pb;

// 1. IDENTITY & SECURITY GATE (Updated to process.env for Docker)
const isSuperuser = pb.authStore.isValid && (pb.authStore.isAdmin || pb.authStore.model?.collectionName === '_superusers');
const isEmailCorrect = pb.authStore.model?.email === process.env.PB_ADMIN_EMAIL;

// Debug Tripwire
console.log("--- ADMIN ACCESS CHECK ---");
console.log("Is Superuser:", isSuperuser);
console.log("Is Email Correct:", isEmailCorrect);

if (!isSuperuser || !isEmailCorrect) {
    return Astro.redirect('/admin/login');
}

const ADMIN_SECRET = process.env.ADMIN_SECRET;

// Define filters to ONLY pull relevant apps
const userFilter = 'app_context = "docs-chat" || app_context = "pdf-extract" || app_context = "all-in-one"';
const waitlistFilter = 'status = "pending" && (interested_app = "docs-chat" || interested_app = "pdf-extract" || interested_app = "all-in-one")';

// 2. DATA AGGREGATION: STATS
let totalUsers = 0;
let proUsers = 0;
let estimatedMonthlyRevenue = 0;
const PRO_PRICE = 20;

try {
    const allUsers = await pb.collection('users').getFullList({ filter: userFilter });
    totalUsers = allUsers.length;
    proUsers = allUsers.filter(u => u.plan === 'pro' || u.plan === 'all-in-one').length;
    estimatedMonthlyRevenue = proUsers * PRO_PRICE;
} catch (e) { console.error("Stats Fetch Error:", e); }

// 3. DATA AGGREGATE: PENDING WAITLIST
let requests = [];
try {
    requests = await pb.collection('waitlist').getFullList({
        filter: waitlistFilter,
        sort: '-created'
    });
} catch (e) { console.error("Waitlist Fetch Error:", e); }

// 4. DATA AGGREGATE: RECENT APPROVALS
let recentApprovals = { items: [] };
try {
    recentApprovals = await pb.collection('users').getList(1, 5, { 
        filter: userFilter, 
        sort: '-created' 
    });
} catch (e) { console.error("Recent Approvals Error:", e); }

// 5. DATA AGGREGATE: GROWTH CHART
const growthData = [];
const now = new Date();
try {
    const allUsers = await pb.collection('users').getFullList({ 
        filter: userFilter, 
        sort: 'created' 
    });
    for (let i = 6; i >= 0; i--) {
        const date = new Date();
        date.setDate(now.getDate() - i);
        const dateString = date.toISOString().split('T')[0]; // YYYY-MM-DD
        const dayName = date.toLocaleDateString('en-US', { weekday: 'short' });

        // Use .includes to match the date part of the ISO string
        const count = allUsers.filter(u => u.created.includes(dateString)).length;
        growthData.push({ day: dayName, count });
    }
} catch (e) { console.error("Growth Data Error:", e); }

const maxCount = Math.max(...growthData.map(d => d.count), 1);
---

<DashboardLayout title="Admin Command Center">

    <style is:global>
        @media print {
            body { background: white !important; color: black !important; }
            .no-print, button, form, nav, header { display: none !important; }
            .bg-gray-900, .bg-gray-950 { background: white !important; border: 1px solid #eee !important; }
            .text-white, .text-gray-200 { color: black !important; }
            .shadow-xl, .shadow-2xl, .shadow-3xl { shadow: none !important; }
            .rounded-3xl, .rounded-2xl { border-radius: 4px !important; }
            .bg-blue-600 { background: #2563eb !important; -webkit-print-color-adjust: exact; }
            .grid { display: block !important; }
            .mb-12, .mb-10 { margin-bottom: 20px !important; page-break-inside: avoid; }
        }
    </style>

    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8 pb-6 border-b border-gray-800 no-print">
        <div>
            <h1 class="text-3xl font-black text-white tracking-tighter italic uppercase">Command Center</h1>
            <div class="flex items-center gap-2 mt-1">
                <span class="flex h-2 w-2 rounded-full bg-green-500 animate-pulse"></span>
                <p class="text-[10px] font-mono text-gray-500 uppercase tracking-widest">Node: {Astro.request.headers.get('host') || 'Production'}</p>
            </div>
        </div>

        <div class="flex items-center gap-3">
            <button onclick="window.print()" class="bg-gray-800 hover:bg-gray-700 text-white px-4 py-2 rounded-xl text-xs font-bold transition flex items-center gap-2 border border-gray-700">
                <svg class="w-3.5 h-3.5 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
                Export PDF
            </button>

            <a href="/logout" class="bg-red-500/10 hover:bg-red-500/20 text-red-500 px-4 py-2 rounded-xl text-xs font-bold border border-red-500/20 transition flex items-center gap-2">
                Sign Out
            </a>
        </div>
    </div>

    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-10">
        <div class="bg-gray-900/40 border border-gray-800/50 p-4 rounded-2xl">
            <p class="text-[10px] text-gray-500 uppercase font-black tracking-widest mb-1">Database</p>
            <p class="text-sm font-mono text-green-400">Stable</p>
        </div>
        <div class="bg-gray-900/40 border border-gray-800/50 p-4 rounded-2xl">
            <p class="text-[10px] text-gray-500 uppercase font-black tracking-widest mb-1">API Engine</p>
            <p class="text-sm font-mono text-blue-400">V5.0 Edge</p>
        </div>
        <div class="bg-gray-900/40 border border-gray-800/50 p-4 rounded-2xl">
            <p class="text-[10px] text-gray-500 uppercase font-black tracking-widest mb-1">Status</p>
            <p class="text-sm font-mono text-purple-400">Production</p>
        </div>
        <div class="bg-gray-900/40 border border-gray-800/50 p-4 rounded-2xl">
            <p class="text-[10px] text-gray-500 uppercase font-black tracking-widest mb-1">Generated</p>
            <p class="text-sm font-mono text-gray-400">{new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}</p>
        </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12">
        <div class="bg-gray-900 border border-gray-800 p-6 rounded-3xl shadow-xl relative overflow-hidden">
            <p class="text-gray-500 text-[10px] font-black uppercase tracking-widest mb-1">Total Users</p>
            <h4 class="text-5xl font-black text-white">{totalUsers}</h4>
        </div>
        <div class="bg-gray-900 border border-gray-800 p-6 rounded-3xl shadow-xl relative overflow-hidden">
            <p class="text-gray-500 text-[10px] font-black uppercase tracking-widest mb-1">Pro Tier</p>
            <h4 class="text-5xl font-black text-blue-400">{proUsers}</h4>
        </div>
        <div class="bg-gray-900 border border-gray-800 p-6 rounded-3xl shadow-xl relative overflow-hidden">
            <p class="text-gray-500 text-[10px] font-black uppercase tracking-widest mb-1">Revenue</p>
            <h4 class="text-5xl font-black text-green-400">${estimatedMonthlyRevenue}</h4>
        </div>
    </div>

    <div class="bg-gray-900 border border-gray-800 rounded-3xl p-8 mb-12 shadow-2xl">
        <h3 class="text-white font-bold text-xl tracking-tight mb-8">Acquisition Velocity (7D)</h3>
        <div class="flex items-end justify-between gap-4 h-48 w-full group px-2">
            {growthData.map((data) => (
                <div class="flex-1 flex flex-col items-center gap-3">
                    <div class="w-full bg-blue-600 rounded-t-lg" style={`height: ${(data.count / maxCount) * 100}%`}></div>
                    <span class="text-gray-600 text-[10px] font-black uppercase tracking-tighter">{data.day}</span>
                </div>
            ))}
        </div>
    </div>

    <div class="mb-8 no-print">
        <h2 class="text-2xl font-bold text-white tracking-tight">Pending Approval Queue</h2>
    </div>

    <div class="grid gap-4 mb-16 no-print">
        {requests.length === 0 && (
            <div class="bg-gray-950 border border-gray-900 rounded-2xl p-6 text-center text-gray-500">
                No pending requests.
            </div>
        )}
        {requests.map((req) => (
            <div class="bg-gray-950 border border-gray-900 rounded-2xl p-6 flex flex-col md:flex-row justify-between items-center gap-4" id={`row-${req.id}`}>
                <div class="flex-1">
                    <span class="text-lg font-bold text-gray-100">{req.name}</span>
                    <p class="text-xs text-gray-500 font-mono">{req.email}</p>
                </div>
                <button onclick={`approveUser('${req.id}', '${req.email}', '${req.name}', '${req.interested_app}')`} class="bg-blue-600 hover:bg-blue-500 text-white text-[10px] font-black uppercase tracking-widest px-8 py-4 rounded-xl">
                    Grant Access
                </button>
            </div>
        ))}
    </div>

    <div class="mb-8">
        <h2 class="text-2xl font-bold text-white tracking-tight">System Audit Log</h2>
        <p class="text-sm text-gray-500">Last 5 provisioned accounts.</p>
    </div>

    <div class="bg-gray-900/50 border border-gray-800 rounded-3xl overflow-hidden mb-12 shadow-2xl">
        <table class="w-full text-left">
            <thead class="bg-gray-900">
                <tr>
                    <th class="px-6 py-4 text-[10px] font-black text-gray-500 uppercase tracking-widest">User</th>
                    <th class="px-6 py-4 text-[10px] font-black text-gray-500 uppercase tracking-widest">App</th>
                    <th class="px-6 py-4 text-[10px] font-black text-gray-500 uppercase tracking-widest text-right">Date</th>
                </tr>
            </thead>
            <tbody class="divide-y divide-gray-800/50">
                {recentApprovals.items.length === 0 && (
                    <tr>
                        <td colspan="3" class="px-6 py-8 text-center text-gray-500">No recent approvals found.</td>
                    </tr>
                )}
                {recentApprovals.items.map((user) => (
                    <tr>
                        <td class="px-6 py-4 text-sm font-bold text-gray-200">{user.email}</td>
                        <td class="px-6 py-4 text-[9px] text-blue-400 font-black uppercase tracking-widest">{user.app_context || 'INTERNAL'}</td>
                        <td class="px-6 py-4 text-right text-[10px] text-gray-500 font-mono">{new Date(user.created).toLocaleDateString()}</td>
                    </tr>
                ))}
            </tbody>
        </table>
    </div>

    <script is:inline define:vars={{ ADMIN_SECRET }}>
        // 1. Attach to window so the HTML onclick can see it outside the Astro sandbox
        window.approveUser = async function(id, email, name, app_context) {
            // 2. Find the exact button inside the specific row
            const row = document.getElementById(`row-${id}`);
            const btn = row.querySelector('button');

            btn.innerText = "PROVISIONING...";
            btn.disabled = true;

            try {
                // Generate a temporary password
                const tempPassword = Math.random().toString(36).slice(-10) + "!";

                const response = await fetch('https://api.rajasekhar.digital/api/approve-user', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        email,
                        name,
                        password: tempPassword,
                        app_context,
                        adminSecret: ADMIN_SECRET
                    })
                });

                if (response.ok) {
                    row.style.opacity = '0.3';
                    btn.innerText = "Provisioned";
                } else {
                    throw new Error(`API returned status ${response.status}`);
                }
            } catch (err) {
                alert(`ENGINE FAILURE: ${err.message}`);
                btn.innerText = "GRANT ACCESS";
                btn.disabled = false;
            }
        };
    </script>
</DashboardLayout>