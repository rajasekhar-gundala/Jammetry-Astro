---
import '../../styles/global.css';

const pb = Astro.locals.pb;

if (!pb.authStore.isValid) {
  return Astro.redirect('/login');
}

let user = Astro.locals.user;
try {
  const authData = await pb.collection('users').authRefresh({}, { $autoCancel: false });
  user = authData.record;
  const cookie = pb.authStore.exportToCookie({ httpOnly: false, secure: false });
  Astro.response.headers.append('set-cookie', cookie);
} catch (e) {
  console.error("Dashboard sync failure:", e);
}

const userPlans = Array.isArray(user.plan_type) ? user.plan_type : [user.plan_type].filter(Boolean);
const userModules = Array.isArray(user.active_modules) ? user.active_modules : [user.active_modules].filter(Boolean);

const isProTier = userPlans.includes('pro');
const isProPlusTier = userPlans.includes('pro-plus');
const isEnterpriseTier = userPlans.includes('enterprise');

const hasChat = userModules.includes('chat');
const hasExtract = userModules.includes('extract');
const hasBundle = hasChat && hasExtract;

// Fetch Metrics
let pdfCount = 0;
try {
  const result = await pb.collection('sales_data').getList(1, 1, { filter: `user_id = "${user.id}"` });
  pdfCount = result.totalItems;
} catch (err) {}

const docCount = user.documentCount || 0;
const totalUsage = docCount + pdfCount;

let maxDocs = 3;
if (isProTier) maxDocs = 299;
if (isProPlusTier) maxDocs = 399;
if (isEnterpriseTier) maxDocs = 999999; 

const progressPercent = isEnterpriseTier ? 100 : Math.min((totalUsage / maxDocs) * 100, 100);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Dashboard Hub | AI Copilot</title>
  </head>
  <body class="bg-gray-950 text-gray-100 font-sans antialiased min-h-screen flex flex-col">

    {/* Top Navigation */}
    <nav class="border-b border-gray-800 bg-gray-900 sticky top-0 z-40">
      <div class="max-w-7xl mx-auto px-6 h-16 flex items-center justify-between">
        <div class="text-xl font-black text-white flex items-center gap-2">
          <div class="w-8 h-8 bg-blue-600 rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          </div>
          AI Copilot
        </div>
        
        <div class="flex items-center gap-4">
          <a href="/dashboard/billing" class="text-sm font-bold text-gray-400 hover:text-white transition">Billing</a>
          <a href="/dashboard/profile" class="flex items-center gap-2 bg-gray-800 hover:bg-gray-700 border border-gray-700 px-3 py-1.5 rounded-full transition">
            <div class="w-6 h-6 rounded-full bg-gradient-to-tr from-blue-500 to-purple-500 flex items-center justify-center text-xs font-bold text-white">
              {user.email.charAt(0).toUpperCase()}
            </div>
            <span class="text-sm font-medium text-gray-300">{user.email.split('@')[0]}</span>
          </a>
        </div>
      </div>
    </nav>

    <main class="max-w-7xl mx-auto px-6 py-10 w-full flex-grow">
      
      {/* Welcome Header */}
      <div class="mb-10">
        <h1 class="text-3xl font-bold text-white mb-2">Welcome back to your workspace.</h1>
        <p class="text-gray-400">Select an AI module below to start working, or check your current utilization.</p>
      </div>

      {/* High-Level Metrics Row */}
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
        
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 shadow-lg">
          <div class="flex justify-between items-start mb-4">
            <div class="p-2 bg-blue-500/10 text-blue-400 rounded-lg">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path></svg>
            </div>
            {isEnterpriseTier ? <span class="text-xs font-bold bg-purple-500/20 text-purple-400 px-2 py-1 rounded border border-purple-500/30">Enterprise</span> :
             isProPlusTier ? <span class="text-xs font-bold bg-blue-500/20 text-blue-400 px-2 py-1 rounded border border-blue-500/30">Pro Plus</span> :
             isProTier ? <span class="text-xs font-bold bg-green-500/20 text-green-400 px-2 py-1 rounded border border-green-500/30">Pro Tier</span> :
             <span class="text-xs font-bold bg-gray-800 text-gray-400 px-2 py-1 rounded border border-gray-700">Free Tier</span>}
          </div>
          <h3 class="text-gray-400 text-sm font-bold uppercase tracking-wider mb-1">Total Monthly Volume</h3>
          <div class="flex items-baseline gap-2 mb-3">
            <span class="text-3xl font-black text-white">{totalUsage}</span>
            <span class="text-gray-500 text-sm">/ {isEnterpriseTier ? '∞' : maxDocs}</span>
          </div>
          <div class="w-full bg-gray-950 border border-gray-800 rounded-full h-1.5 overflow-hidden">
            <div class="bg-blue-500 h-full rounded-full" style={`width: ${progressPercent}%`}></div>
          </div>
        </div>

        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 shadow-lg">
          <div class="flex justify-between items-start mb-4">
            <div class="p-2 bg-purple-500/10 text-purple-400 rounded-lg">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
            </div>
            {!hasChat && <span class="text-xs font-bold bg-red-500/10 text-red-400 px-2 py-1 rounded border border-red-500/20">Locked</span>}
          </div>
          <h3 class="text-gray-400 text-sm font-bold uppercase tracking-wider mb-1">Knowledge Base Docs</h3>
          <span class="text-3xl font-black text-white">{docCount}</span>
        </div>

        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 shadow-lg">
          <div class="flex justify-between items-start mb-4">
            <div class="p-2 bg-green-500/10 text-green-400 rounded-lg">
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            </div>
            {!hasExtract && <span class="text-xs font-bold bg-red-500/10 text-red-400 px-2 py-1 rounded border border-red-500/20">Locked</span>}
          </div>
          <h3 class="text-gray-400 text-sm font-bold uppercase tracking-wider mb-1">Invoices Extracted</h3>
          <span class="text-3xl font-black text-white">{pdfCount}</span>
        </div>

      </div>

      <h2 class="text-xl font-bold text-white mb-6">Your Applications</h2>

      {/* Application Hub Grid */}
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">

        {/* App 1: Document Chat */}
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 shadow-xl flex flex-col relative overflow-hidden transition hover:border-gray-700">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-purple-600 rounded-xl flex items-center justify-center shadow-lg shadow-purple-600/20">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
            </div>
            <div>
              <h2 class="text-2xl font-bold text-white">Document Chat</h2>
              <p class="text-sm text-gray-400">Conversational AI for your PDFs</p>
            </div>
          </div>
          
          <p class="text-gray-400 text-sm mb-8 flex-grow">Upload internal company knowledge, manuals, or research papers and instantly converse with them using our high-accuracy RAG engine.</p>
          
          {hasChat ? (
            <a href="/dashboard/chat" class="w-full text-center bg-blue-600 hover:bg-blue-500 text-white font-bold py-3.5 rounded-xl transition shadow-lg shadow-blue-600/20">
              Launch Application
            </a>
          ) : (
            <div class="bg-gray-950 border border-gray-800 rounded-xl p-4 flex items-center justify-between">
              <span class="text-sm text-gray-400 font-medium">Module Not Active</span>
              <a href="/dashboard/billing" class="text-sm text-blue-400 hover:text-blue-300 font-bold transition flex items-center gap-1">
                Unlock Now <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </a>
            </div>
          )}
        </div>

        {/* App 2: Invoice Extraction */}
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 shadow-xl flex flex-col relative overflow-hidden transition hover:border-gray-700">
          <div class="flex items-center gap-4 mb-4">
            <div class="w-12 h-12 bg-green-600 rounded-xl flex items-center justify-center shadow-lg shadow-green-600/20">
              <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path></svg>
            </div>
            <div>
              <h2 class="text-2xl font-bold text-white">Invoice Analytics</h2>
              <p class="text-sm text-gray-400">Automated Financial Extraction</p>
            </div>
          </div>

          <p class="text-gray-400 text-sm mb-8 flex-grow">Eliminate manual data entry. Upload unstructured sales invoices and automatically extract vendor details, line items, and totals into structured JSON.</p>
          
          {hasExtract ? (
            <a href="/dashboard/extract" class="w-full text-center bg-blue-600 hover:bg-blue-500 text-white font-bold py-3.5 rounded-xl transition shadow-lg shadow-blue-600/20">
              Launch Application
            </a>
          ) : (
            <div class="bg-gray-950 border border-gray-800 rounded-xl p-4 flex items-center justify-between">
              <span class="text-sm text-gray-400 font-medium">Module Not Active</span>
              <a href="/dashboard/billing" class="text-sm text-blue-400 hover:text-blue-300 font-bold transition flex items-center gap-1">
                Unlock Now <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path></svg>
              </a>
            </div>
          )}
        </div>

      </div>

    </main>
  </body>
</html>