---
import '../../styles/global.css';

const pb = Astro.locals.pb;

// 1. Protect the route - ensure session is active
if (!pb.authStore.isValid) {
  return Astro.redirect('/login');
}

const user = Astro.locals.user;
let message = '';
let error = '';

// 2. Dynamic Navigation & Context Logic
// This ensures a PDF user doesn't see "Back to Chat"
const backLink = user.app_context === 'pdf-extract' ? '/extract' : '/chat';
const backLabel = user.app_context === 'pdf-extract' ? 'Back to Extraction' : 'Back to Chat';

// 3. Fetch PDF Extraction Stats
// We only query the sales_data collection if the user is in that context
let pdfCount = 0;
if (user.app_context === 'pdf-extract') {
  try {
    const result = await pb.collection('sales_data').getList(1, 1, {
      filter: `user_id = "${user.id}"`,
    });
    pdfCount = result.totalItems;
  } catch (err) {
    console.error("Stats Fetch Error:", err);
  }
}

// 4. Handle Password Change Form Submission
if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const oldPassword = data.get('oldPassword');
    const password = data.get('password');
    const passwordConfirm = data.get('passwordConfirm');

    // PocketBase requires oldPassword to verify identity for client-side updates
    await pb.collection('users').update(user.id, {
      oldPassword,
      password,
      passwordConfirm
    });

    message = 'Password updated successfully!';
  } catch (err) {
    console.error(err);
    error = 'Failed to update password. Please check your old password and try again.';
  }
}
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Profile Settings | AI Copilot</title>
  </head>
  <body class="bg-gray-950 text-gray-100 font-sans antialiased min-h-screen">

    <nav class="border-b border-gray-800 bg-gray-900">
      <div class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
        <div class="text-xl font-bold text-white">
          Settings
        </div>
        <a href={backLink} class="text-gray-400 hover:text-white transition text-sm flex items-center gap-2">
          &larr; {backLabel}
        </a>
      </div>
    </nav>

    <main class="max-w-4xl mx-auto px-6 py-12 grid md:grid-cols-3 gap-8">

      <div class="md:col-span-1 space-y-6">
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 relative overflow-hidden">

          {user.plan === 'pro' && (
            <div class="absolute -top-10 -right-10 w-32 h-32 bg-blue-500/20 blur-3xl rounded-full pointer-events-none"></div>
          )}

          <div class="w-16 h-16 rounded-full bg-gradient-to-tr from-blue-500 to-purple-500 flex items-center justify-center text-2xl font-bold mb-4 shadow-lg relative z-10">
            {user.email.charAt(0).toUpperCase()}
          </div>
          <h2 class="text-lg font-bold truncate relative z-10">{user.email}</h2>
          <p class="text-sm text-gray-500 mb-6 relative z-10">Account ID: {user.id}</p>

          <div class="pt-4 border-t border-gray-800 relative z-10">
            <p class="text-sm text-gray-400 mb-1">Current Plan</p>
            <div class="flex items-center gap-2">
              {user.plan === 'pro' ? (
                <span class="bg-gradient-to-r from-blue-500 to-purple-500 text-white px-3 py-1 rounded-full text-sm font-bold uppercase tracking-wide shadow-[0_0_15px_-3px_rgba(37,99,235,0.5)]">
                  Pro Tier
                </span>
              ) : (
                <span class="bg-gray-800 text-gray-300 px-3 py-1 rounded-full text-sm font-bold uppercase tracking-wide border border-gray-700">
                  Free Tier
                </span>
              )}
            </div>

            <div class="mt-6 flex flex-col gap-4">
              {user.app_context === 'docs-chat' && (
                <div>
                  <p class="text-xs text-gray-400 uppercase font-bold tracking-wider mb-1">Documents Indexed</p>
                  <p class="text-white font-medium text-lg">
                    {user.documentCount || 0}
                    <span class="text-gray-500 text-sm font-normal">/ {user.plan === 'pro' ? '∞' : '3'}</span>
                  </p>
                </div>
              )}

              {user.app_context === 'pdf-extract' && (
                <div>
                  <p class="text-xs text-gray-400 uppercase font-bold tracking-wider mb-1">Invoices Extracted</p>
                  <p class="text-white font-medium text-lg">
                    {pdfCount}
                    <span class="text-gray-500 text-sm font-normal">/ {user.plan === 'pro' ? '∞' : '10'}</span>
                  </p>
                </div>
              )}
            </div>

            {user.plan !== 'pro' ? (
              <a
                href={`https://buy.stripe.com/test_bJe8wRfSmgkS7S79lh4Rq00?client_reference_id=${user.id}&prefilled_email=${user.email}`}
                class="mt-8 block w-full bg-white hover:bg-gray-100 text-gray-950 text-center font-bold py-3 rounded-xl transition shadow-[0_0_20px_-5px_rgba(255,255,255,0.3)] flex items-center justify-center gap-2"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                Upgrade to Pro
              </a>
            ) : (
              <button
                id="manage-billing-btn"
                class="mt-8 w-full bg-gray-800 hover:bg-gray-700 text-white text-center font-bold py-3 rounded-xl transition border border-gray-700 flex items-center justify-center gap-2"
              >
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"></path></svg>
                Manage Subscription
              </button>
            )}

          </div>
        </div>
      </div>

      <div class="md:col-span-2">
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 md:p-8 shadow-2xl">
          <h3 class="text-xl font-bold mb-2 text-white">Change Password</h3>
          <p class="text-gray-400 text-sm mb-6">Ensure your account is using a long, random password to stay secure.</p>

          {message && <div class="bg-green-500/10 border border-green-500/50 text-green-400 p-4 rounded-xl text-sm mb-6 font-medium">{message}</div>}
          {error && <div class="bg-red-500/10 border border-red-500/50 text-red-400 p-4 rounded-xl text-sm mb-6 font-medium">{error}</div>}

          <form method="POST" class="space-y-5 max-w-md">
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1.5">Current Password</label>
              <input type="password" name="oldPassword" required class="w-full bg-gray-950 border border-gray-700 rounded-xl px-4 py-3 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition text-white" placeholder="Enter current password" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1.5">New Password</label>
              <input type="password" name="password" required minlength="8" class="w-full bg-gray-950 border border-gray-700 rounded-xl px-4 py-3 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition text-white" placeholder="Minimum 8 characters" />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-300 mb-1.5">Confirm New Password</label>
              <input type="password" name="passwordConfirm" required minlength="8" class="w-full bg-gray-950 border border-gray-700 rounded-xl px-4 py-3 focus:outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition text-white" placeholder="Must match new password" />
            </div>
            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3.5 rounded-xl transition mt-4 shadow-lg shadow-blue-600/20">
              Update Password
            </button>
          </form>
        </div>
      </div>

    </main>

  <script define:vars={{ userId: user.id }}>
      const manageBtn = document.getElementById('manage-billing-btn');

      if (manageBtn) {
        manageBtn.addEventListener('click', async () => {
          manageBtn.textContent = 'Contacting Stripe...';
          manageBtn.disabled = true;
          try {
            // Points to your dedicated Node.js API subdomain
            const res = await fetch('https://api.jammetry.com/api/portal', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ userId })
            });
            const data = await res.json();

            if (data.url) {
              window.location.href = data.url;
            } else {
              alert('Could not open billing portal. Please contact support.');
              manageBtn.textContent = 'Manage Subscription';
              manageBtn.disabled = false;
            }
          } catch (err) {
            console.error(err);
            alert('Network error - Please check your connection.');
            manageBtn.textContent = 'Manage Subscription';
            manageBtn.disabled = false;
          }
        });
      }
    </script>
  </body>
</html>