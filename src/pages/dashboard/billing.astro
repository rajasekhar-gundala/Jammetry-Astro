---
import '../../styles/global.css';

const pb = Astro.locals.pb;

if (!pb.authStore.isValid) {
  return Astro.redirect('/login');
}

let user = Astro.locals.user;
try {
  const authData = await pb.collection('users').authRefresh({}, { $autoCancel: false });
  user = authData.record;
  const cookie = pb.authStore.exportToCookie({ httpOnly: false, secure: false });
  Astro.response.headers.append('set-cookie', cookie);
} catch (e) {}

const userPlans = Array.isArray(user.plan_type) ? user.plan_type : [user.plan_type].filter(Boolean);
const isProTier = userPlans.includes('pro');
const isProPlusTier = userPlans.includes('pro-plus');
const isEnterpriseTier = userPlans.includes('enterprise');
const isPremium = isProTier || isProPlusTier || isEnterpriseTier;

let pdfCount = 0;
try {
  const result = await pb.collection('sales_data').getList(1, 1, { filter: `user_id = "${user.id}"` });
  pdfCount = result.totalItems;
} catch (err) {}

const totalUsage = (user.documentCount || 0) + pdfCount;

let maxDocs = 3;
if (isProTier) maxDocs = 299;
if (isProPlusTier) maxDocs = 399;
if (isEnterpriseTier) maxDocs = 999999; 

const progressPercent = isEnterpriseTier ? 100 : Math.min((totalUsage / maxDocs) * 100, 100);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Pricing & Plans | AI Copilot</title>
    <!-- REMEMBER TO PUT YOUR CLIENT ID BACK HERE! -->
    <script is:inline src="https://www.paypal.com/sdk/js?client-id=AdSwDrUHYLD9nXYLIbFr364_lQcNIi1ClmhaXd6feCMKi-dLveGmq2NQZ1TiMEjRKP_CBXPQD5aNs23u&currency=USD"></script>
  </head>
  <body class="bg-gray-950 text-gray-100 font-sans antialiased min-h-screen relative">

    <div id="success-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm">
      <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 max-w-md w-full mx-4 text-center shadow-2xl">
        <div class="w-16 h-16 bg-green-500/20 text-green-400 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-2">Upgrade Successful!</h3>
        <p class="text-gray-400 mb-8">Welcome to premium tier. Your capabilities are now unlocked.</p>
        <button id="modal-close-btn" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 rounded-xl transition">Continue</button>
      </div>
    </div>

    <nav class="border-b border-gray-800 bg-gray-900">
      <div class="max-w-6xl mx-auto px-6 h-16 flex items-center justify-between">
        <div class="text-xl font-bold text-white">Billing Dashboard</div>
        <a href="/dashboard/profile" class="text-gray-400 hover:text-white transition text-sm flex items-center gap-2">&larr; Profile Settings</a>
      </div>
    </nav>

    <main class="max-w-6xl mx-auto px-6 py-12 grid grid-cols-1 lg:grid-cols-4 gap-8">
      
      {/* Sidebar Metrics View */}
      <div class="lg:col-span-1">
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 shadow-2xl sticky top-6">
          <h2 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-4">Current Subscription</h2>
          <div class="mb-6">
            {isEnterpriseTier && <span class="bg-gradient-to-r from-purple-600 to-indigo-600 text-white text-xs font-bold px-3 py-1 rounded-full uppercase">Enterprise</span>}
            {isProPlusTier && <span class="bg-gradient-to-r from-blue-600 to-purple-600 text-white text-xs font-bold px-3 py-1 rounded-full uppercase">Pro Plus</span>}
            {isProTier && <span class="bg-gradient-to-r from-blue-500 to-purple-500 text-white text-xs font-bold px-3 py-1 rounded-full uppercase">Pro Tier</span>}
            {!isPremium && <span class="bg-gray-800 text-gray-300 text-xs font-bold px-3 py-1 rounded-full uppercase border border-gray-700">Free Tier</span>}
          </div>

          <div class="space-y-2">
            <div class="flex justify-between text-xs text-gray-400">
              <span>Monthly Volume</span>
              <span class="text-white font-bold">{totalUsage} / {isEnterpriseTier ? '∞' : maxDocs}</span>
            </div>
            <div class="w-full bg-gray-950 border border-gray-800 rounded-full h-2 overflow-hidden">
              <div class="bg-blue-500 h-full rounded-full" style={`width: ${progressPercent}%`}></div>
            </div>
          </div>
        </div>
      </div>

      {/* Interactive Pricing View */}
      <div class="lg:col-span-3 space-y-8">
        
        {/* 👇 THE FIX: Removed the !isPremium check here so toggles ALWAYS show */}
        <div class="flex flex-col items-center justify-center space-y-6 mb-10">
          {/* App Selector */}
          <div class="bg-gray-900 p-1.5 rounded-2xl flex flex-col sm:flex-row gap-2 border border-gray-800 shadow-lg w-full max-w-2xl">
            <button data-app="chat" class="app-toggle flex-1 py-3 px-4 rounded-xl text-sm font-bold text-gray-400 hover:text-white transition focus:outline-none">💬 Document Chat</button>
            <button data-app="extract" class="app-toggle flex-1 py-3 px-4 rounded-xl text-sm font-bold text-gray-400 hover:text-white transition focus:outline-none">📄 Invoice Extraction</button>
            <button data-app="bundle" class="app-toggle active bg-blue-600 text-white flex-1 py-3 px-4 rounded-xl text-sm font-bold shadow-md transition focus:outline-none">🚀 All-in-One Bundle</button>
          </div>

          {/* Cycle Selector */}
          <div class="bg-gray-900 p-1 rounded-full inline-flex border border-gray-800 shadow-md">
            <button data-cycle="monthly" class="cycle-toggle active px-6 py-2 rounded-full text-sm font-bold bg-gray-700 text-white transition focus:outline-none">Monthly</button>
            <button data-cycle="yearly" class="cycle-toggle px-6 py-2 rounded-full text-sm font-bold text-gray-400 hover:text-white transition focus:outline-none">Yearly <span class="text-green-400 ml-1 text-xs">-20%</span></button>
          </div>
        </div>

        {/* Tier 1: Pro */}
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 flex flex-col md:flex-row justify-between md:items-center gap-6 relative overflow-hidden transition-all duration-300">
          <div class="space-y-2">
            <h3 class="text-xl font-bold text-white">Pro</h3>
            <p class="text-gray-400 text-sm max-w-md">Standard AI capabilities. Handles up to <b id="ui-docs-pro" class="text-gray-200">299</b> documents parsed per month.</p>
          </div>
          <div class="flex flex-col items-end gap-3 min-w-[200px]">
            <div class="text-3xl font-black text-white">$<span id="ui-price-pro">59</span><span id="ui-cycle-pro" class="text-xs text-gray-500 font-normal">/mo</span></div>
            
            {isProTier ? (
              <span class="text-xs bg-green-500/20 text-green-400 font-bold px-4 py-2 border border-green-500/30 rounded-xl">Current Active Tier</span>
            ) : (isProPlusTier || isEnterpriseTier) ? (
              <span class="text-xs text-gray-500 font-medium">Included in Plan</span>
            ) : (
              <div id="paypal-pro-container" class="w-full"></div>
            )}
          </div>
        </div>

        {/* Tier 2: Pro Plus */}
        <div class="bg-gray-900 border border-blue-900/50 rounded-2xl p-6 flex flex-col md:flex-row justify-between md:items-center gap-6 relative overflow-hidden transition-all duration-300 shadow-[0_0_30px_-10px_rgba(37,99,235,0.2)]">
          <div class="absolute top-0 right-12 bg-blue-600 text-white font-bold text-[10px] px-3 py-1 rounded-b-lg uppercase tracking-widest shadow-md">Recommended</div>
          <div class="space-y-2">
            <h3 class="text-xl font-bold text-white">Pro Plus</h3>
            <p class="text-gray-400 text-sm max-w-md">Extended processing infrastructure. Handles up to <b id="ui-docs-plus" class="text-gray-200">399</b> documents per billing step.</p>
          </div>
          <div class="flex flex-col items-end gap-3 min-w-[200px]">
            <div class="text-3xl font-black text-white">$<span id="ui-price-plus">79</span><span id="ui-cycle-plus" class="text-xs text-gray-500 font-normal">/mo</span></div>
            
            {isProPlusTier ? (
              <span class="text-xs bg-green-500/20 text-green-400 font-bold px-4 py-2 border border-green-500/30 rounded-xl">Current Active Tier</span>
            ) : isEnterpriseTier ? (
              <span class="text-xs text-gray-500 font-medium">Included in Plan</span>
            ) : (
              <div id="paypal-plus-container" class="w-full"></div>
            )}
          </div>
        </div>

        {/* Tier 3: Enterprise */}
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 flex flex-col md:flex-row justify-between md:items-center gap-6">
          <div class="space-y-2">
            <h3 class="text-lg font-bold text-purple-400">Enterprise Context</h3>
            <p class="text-gray-400 text-sm max-w-md">Infinite context scale, dedicated multi-tenant deployment, and priority SLA.</p>
          </div>
          <div class="min-w-[200px] flex justify-end">
            {isEnterpriseTier ? (
              <span class="text-xs bg-purple-500/20 text-purple-400 font-bold px-4 py-2 border border-purple-500/30 rounded-xl">Active Corporate Account</span>
            ) : (
              <a href={`mailto:sales@jammetry.com?subject=Enterprise%20Upgrade%20Request%20-%20ID:%20${user.id}`} class="w-full text-center bg-purple-600 hover:bg-purple-500 font-bold px-4 py-3 rounded-xl transition text-sm shadow-lg shadow-purple-600/10">Contact Custom Pricing</a>
            )}
          </div>
        </div>

      </div>
    </main>

    <!-- 👇 CLIENT-SIDE LOGIC FOR DYNAMIC PRICING & PAYPAL -->
    <script define:vars={{ userId: user.id, isProTier, isProPlusTier, isEnterpriseTier }}>
      
      // 1. State Management Matrix
      let state = { app: 'bundle', cycle: 'monthly' };

      const pricingMatrix = {
        monthly: {
          chat: { proPrice: "39.00", plusPrice: "59.00", proDocs: "199", plusDocs: "299" },
          extract: { proPrice: "39.00", plusPrice: "59.00", proDocs: "199", plusDocs: "299" },
          bundle: { proPrice: "59.00", plusPrice: "79.00", proDocs: "299", plusDocs: "399" }
        },
        yearly: { // 20% Discount
          chat: { proPrice: "374.00", plusPrice: "566.00", proDocs: "199", plusDocs: "299" },
          extract: { proPrice: "374.00", plusPrice: "566.00", proDocs: "199", plusDocs: "299" },
          bundle: { proPrice: "566.00", plusPrice: "758.00", proDocs: "299", plusDocs: "399" }
        }
      };

      // 2. UI Update Function
      const updateUI = () => {
        const data = pricingMatrix[state.cycle][state.app];
        
        document.getElementById('ui-price-pro').innerText = parseInt(data.proPrice);
        document.getElementById('ui-price-plus').innerText = parseInt(data.plusPrice);
        
        document.getElementById('ui-docs-pro').innerText = data.proDocs;
        document.getElementById('ui-docs-plus').innerText = data.plusDocs;

        const cycleSuffix = state.cycle === 'monthly' ? '/mo' : '/yr';
        document.getElementById('ui-cycle-pro').innerText = cycleSuffix;
        document.getElementById('ui-cycle-plus').innerText = cycleSuffix;
      };

      // 3. Event Listeners for Toggles
      document.querySelectorAll('.app-toggle').forEach(btn => {
        btn.addEventListener('click', (e) => {
          document.querySelectorAll('.app-toggle').forEach(b => {
            b.classList.remove('bg-blue-600', 'text-white', 'shadow-md', 'active');
            b.classList.add('text-gray-400');
          });
          e.target.classList.remove('text-gray-400');
          e.target.classList.add('bg-blue-600', 'text-white', 'shadow-md', 'active');
          state.app = e.target.dataset.app;
          updateUI();
        });
      });

      document.querySelectorAll('.cycle-toggle').forEach(btn => {
        btn.addEventListener('click', (e) => {
          document.querySelectorAll('.cycle-toggle').forEach(b => {
            b.classList.remove('bg-gray-700', 'text-white', 'active');
            b.classList.add('text-gray-400');
          });
          const target = e.target.closest('.cycle-toggle');
          target.classList.remove('text-gray-400');
          target.classList.add('bg-gray-700', 'text-white', 'active');
          state.cycle = target.dataset.cycle;
          updateUI();
        });
      });

      // 4. PayPal Integration (Reads Live State!)
      const setupPayPalTier = (containerId, planKey) => {
        const mountTarget = document.getElementById(containerId);
        if (!mountTarget) return;

        window.paypal.Buttons({
          style: { layout: 'horizontal', color: 'gold', shape: 'rect', label: 'paypal', tagline: false },
          createOrder: async () => {
            const currentPrice = planKey === 'pro' ? pricingMatrix[state.cycle][state.app].proPrice : pricingMatrix[state.cycle][state.app].plusPrice;

            const res = await fetch("https://api.jammetry.com/api/paypal/create-order", {
              method: "POST", headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ 
                userId, 
                tier: planKey, 
                value: currentPrice, 
                purchasedModule: state.app, 
                billingCycle: state.cycle 
              }),
            });
            const orderData = await res.json();
            return orderData.id;
          },
          onApprove: async (data) => {
            mountTarget.innerHTML = '<div class="text-xs text-gray-400 animate-pulse">Capturing processing instance...</div>';
            const res = await fetch("https://api.jammetry.com/api/paypal/capture-order", {
              method: "POST", headers: { "Content-Type": "application/json" },
              body: JSON.stringify({ 
                orderID: data.orderID, 
                userId, 
                tier: planKey, 
                purchasedModule: state.app 
              }),
            });
            const captureData = await res.json();
            if (captureData.success) {
              document.getElementById('success-modal').classList.remove('hidden');
              document.getElementById('modal-close-btn').addEventListener('click', () => window.location.reload());
            } else {
              alert("Capture transaction rejected by payment processing matrix.");
              window.location.reload();
            }
          }
        }).render(`#${containerId}`);
      };

      const bootLoop = () => {
        if (window.paypal) {
          if (!isProTier && !isProPlusTier && !isEnterpriseTier) {
            setupPayPalTier('paypal-pro-container', 'pro');
          }
          if (!isProPlusTier && !isEnterpriseTier) {
            setupPayPalTier('paypal-plus-container', 'pro-plus');
          }
        } else {
          setTimeout(bootLoop, 100);
        }
      };

      // Initialize
      updateUI(); // ALWAYS trigger the UI update so prices match the default toggles
      bootLoop();
    </script>
  </body>
</html>