---
import '../../styles/global.css';

const pb = Astro.locals.pb;

if (!pb.authStore.isValid) {
  return Astro.redirect('/login');
}

// 👇 Force fetch live user data to ensure instant UI updates
let user = Astro.locals.user;
try {
  user = await pb.collection('users').getOne(user.id, { $autoCancel: false });
} catch (e) {
  console.error("Live DB fetch failed, using cookie fallback", e);
}

// Robust Pro Check
const isPro = user.plan === 'pro' || user.plan === 'Pro' || user.plan_type === 'all-in-one' || (user.active_modules || []).includes('all-in-one');

let pdfCount = 0;
if (user.app_context === 'pdf-extract') {
  try {
    const result = await pb.collection('sales_data').getList(1, 1, { filter: `user_id = "${user.id}"` });
    pdfCount = result.totalItems;
  } catch (err) {}
}

const pdfLimit = isPro ? 100 : 3; 
const docLimit = isPro ? 100 : 3;
const pdfPercent = isPro ? 100 : Math.min((pdfCount / pdfLimit) * 100, 100);
const docPercent = isPro ? 100 : Math.min(((user.documentCount || 0) / docLimit) * 100, 100);
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Billing & Usage | AI Copilot</title>
    <script is:inline src="https://www.paypal.com/sdk/js?client-id=AdSwDrUHYLD9nXYLIbFr364_lQcNIi1ClmhaXd6feCMKi-dLveGmq2NQZ1TiMEjRKP_CBXPQD5aNs23u&currency=USD"></script>
  </head>
  <body class="bg-gray-950 text-gray-100 font-sans antialiased min-h-screen relative">

    <!-- 👇 THE NEW CUSTOM SUCCESS MODAL -->
    <div id="success-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/80 backdrop-blur-sm">
      <div class="bg-gray-900 border border-gray-800 rounded-2xl p-8 max-w-md w-full mx-4 text-center shadow-[0_0_40px_-10px_rgba(37,99,235,0.3)] animate-in fade-in zoom-in duration-300">
        <div class="w-16 h-16 bg-green-500/20 text-green-400 rounded-full flex items-center justify-center mx-auto mb-6">
          <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-2">Upgrade Successful!</h3>
        <p class="text-gray-400 mb-8">Welcome to Pro. Your account has been upgraded and all AI modules are now unlocked.</p>
        <button id="modal-close-btn" class="w-full bg-blue-600 hover:bg-blue-500 text-white font-bold py-3 rounded-xl transition shadow-lg shadow-blue-600/20">
          Continue to Dashboard
        </button>
      </div>
    </div>

    <nav class="border-b border-gray-800 bg-gray-900">
      <div class="max-w-4xl mx-auto px-6 h-16 flex items-center justify-between">
        <div class="text-xl font-bold text-white">Billing & Usage</div>
        <a href="/dashboard/profile" class="text-gray-400 hover:text-white transition text-sm flex items-center gap-2">
          &larr; Back to Profile
        </a>
      </div>
    </nav>

    <main class="max-w-4xl mx-auto px-6 py-12 grid grid-cols-1 md:grid-cols-3 gap-8">
      
      <div class="md:col-span-1">
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 relative overflow-hidden shadow-2xl">
          <h2 class="text-lg font-bold text-white mb-2 relative z-10">Current Plan</h2>
          
          <div class="flex items-center gap-2 mb-8 relative z-10">
            {isPro ? (
              <span class="bg-gradient-to-r from-blue-500 to-purple-500 text-white px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide shadow-[0_0_15px_-3px_rgba(37,99,235,0.5)]">
                Pro Tier
              </span>
            ) : (
              <span class="bg-gray-800 text-gray-300 px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wide border border-gray-700">
                Free Tier
              </span>
            )}
          </div>
          
          <div class="space-y-6 relative z-10">
            {user.app_context === 'pdf-extract' ? (
              <div>
                <div class="flex justify-between text-sm mb-2">
                  <span class="text-gray-400 font-medium">Extractions</span>
                  <span class="text-white font-bold">{pdfCount} <span class="text-gray-500 font-normal">/ {isPro ? '∞' : '3'}</span></span>
                </div>
                <div class="w-full bg-gray-950 border border-gray-800 rounded-full h-2.5 overflow-hidden">
                  <div class="bg-blue-500 h-full rounded-full transition-all duration-500" style={`width: ${pdfPercent}%`}></div>
                </div>
              </div>
            ) : (
              <div>
                <div class="flex justify-between text-sm mb-2">
                  <span class="text-gray-400 font-medium">Indexed Docs</span>
                  <span class="text-white font-bold">{user.documentCount || 0} <span class="text-gray-500 font-normal">/ {isPro ? '∞' : '3'}</span></span>
                </div>
                <div class="w-full bg-gray-950 border border-gray-800 rounded-full h-2.5 overflow-hidden">
                  <div class="bg-blue-500 h-full rounded-full transition-all duration-500" style={`width: ${docPercent}%`}></div>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>

      <div class="md:col-span-2">
        <div class="bg-gray-900 border border-gray-800 rounded-2xl p-6 md:p-8 shadow-2xl relative overflow-hidden">
          
          {!isPro && (
            <div class="absolute -top-10 -right-10 w-32 h-32 bg-blue-500/10 blur-3xl rounded-full pointer-events-none"></div>
          )}

          <h2 class="text-xl font-bold mb-2 text-white">Pro Plan</h2>
          <p class="text-gray-400 text-sm mb-8">
            Unlock unlimited PDF extractions, advanced table parsing, and priority vector search queries.
          </p>

          <div class="bg-gray-950 rounded-xl p-5 border border-gray-800 mb-8 flex flex-col sm:flex-row justify-between sm:items-center gap-4">
            <div>
              <div class="text-3xl font-bold text-white">$29<span class="text-base text-gray-500 font-normal">/month</span></div>
              <div class="text-sm text-green-400 mt-1 flex items-center gap-1.5 font-medium">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                Includes all AI modules
              </div>
            </div>

            {!isPro ? (
              <div class="relative z-10 w-full sm:w-[200px]">
                <div id="paypal-button-container"></div>
              </div>
            ) : (
              <div class="bg-green-500/10 border border-green-500/50 text-green-400 px-4 py-2 rounded-lg text-sm font-bold flex items-center gap-2">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                Active
              </div>
            )}
          </div>

          <div class="border-t border-gray-800 pt-8">
            <h3 class="text-sm font-bold text-white mb-2 uppercase tracking-wide">Legacy Payment Methods</h3>
            <p class="text-sm text-gray-400 mb-4">If you previously subscribed via Stripe, manage your credit cards and billing history via the secure Stripe portal.</p>
            
            <button 
              id="manage-billing-btn"
              class="text-sm font-bold flex items-center gap-2 transition-colors focus:outline-none"
              class:list={[isPro ? "text-blue-500 hover:text-blue-400" : "text-gray-500 hover:text-gray-400"]}
            >
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"></path></svg>
              Open Stripe Portal
            </button>
          </div>
          
        </div>
      </div>

    </main>

    <script define:vars={{ userId: user.id }}>
      const manageBtn = document.getElementById('manage-billing-btn');
      if (manageBtn) {
        manageBtn.addEventListener('click', async () => {
          manageBtn.innerHTML = 'Contacting Stripe...';
          manageBtn.disabled = true;
          try {
            const res = await fetch('https://api.jammetry.com/api/portal', {
              method: 'POST',
              headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ userId })
            });
            const data = await res.json();
            if (data.url) window.location.href = data.url;
            else alert('Could not open billing portal. Please contact support.');
          } catch (err) {
            console.error(err);
            alert('Network error - Please check your connection.');
          } finally {
            manageBtn.innerHTML = 'Open Stripe Portal';
            manageBtn.disabled = false;
          }
        });
      }

      const renderPayPal = () => {
        if (!document.getElementById('paypal-button-container')) return;

        if (window.paypal) {
          window.paypal.Buttons({
            style: { layout: 'horizontal', color: 'gold', shape: 'rect', label: 'paypal' },
            createOrder: async () => {
              const res = await fetch("https://api.jammetry.com/api/paypal/create-order", {
                method: "POST", headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ userId: userId }),
              });
              const orderData = await res.json();
              if (orderData.error) {
                  alert("Failed to initialize PayPal order: " + orderData.error);
                  return;
              }
              return orderData.id;
            },
            onApprove: async (data) => {
              document.getElementById('paypal-button-container').innerHTML = '<div class="text-white text-sm font-medium animate-pulse">Processing Payment...</div>';

              const res = await fetch("https://api.jammetry.com/api/paypal/capture-order", {
                method: "POST", headers: { "Content-Type": "application/json" },
                body: JSON.stringify({ orderID: data.orderID, userId: userId }),
              });
              const captureData = await res.json();
              
              if (captureData.success) {
                // 👇 Show the custom Tailwind Modal instead of alert()
                document.getElementById('success-modal').classList.remove('hidden');
                
                // When they click "Continue", reload the page to apply the Pro UI
                document.getElementById('modal-close-btn').addEventListener('click', () => {
                  window.location.reload();
                });
              } else {
                alert("Payment capture failed. Please contact support.");
                window.location.reload();
              }
            },
            onError: (err) => {
              console.error("PayPal Frontend Error:", err);
              alert("A network error occurred with PayPal. Please try again.");
            }
          }).render("#paypal-button-container");
        } else {
          setTimeout(renderPayPal, 100);
        }
      };

      renderPayPal();
    </script>
  </body>
</html>