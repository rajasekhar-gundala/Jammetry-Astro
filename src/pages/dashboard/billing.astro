---
// Import your dashboard layout here if you have one! 
// import Layout from '../../layouts/Layout.astro';
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>Billing & Usage</title>
  <!-- NOTE: If you aren't wrapping this in your Layout component, make sure your global CSS is imported here -->
</head>
<body class="bg-[#0B1120] text-white min-h-screen">
  
  <div class="max-w-5xl mx-auto px-6 py-12">
    <div class="flex justify-between items-center mb-10">
      <h1 class="text-3xl font-bold">Billing & Usage</h1>
      <a href="/dashboard/profile" class="text-sm text-gray-400 hover:text-white">&larr; Back to Profile</a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
      
      <!-- Current Usage Card -->
      <div class="col-span-1 bg-[#111827] rounded-2xl p-6 border border-gray-800">
        <h2 class="text-xl font-semibold mb-2">Current Plan</h2>
        <div class="inline-block bg-gray-800 text-gray-300 text-xs px-3 py-1 rounded-full mb-6 font-mono">
          FREE TIER
        </div>
        
        <div class="space-y-4">
          <div>
            <div class="flex justify-between text-sm mb-1">
              <span class="text-gray-400">PDF Extractions</span>
              <span class="text-white font-medium">1 / 3 Daily</span>
            </div>
            <div class="w-full bg-gray-800 rounded-full h-2">
              <div class="bg-blue-500 h-2 rounded-full" style="width: 33%"></div>
            </div>
          </div>
        </div>
      </div>

      <!-- Upgrade / Manage Card -->
      <div class="col-span-1 md:col-span-2 bg-[#111827] rounded-2xl p-6 border border-gray-800">
        <h2 class="text-xl font-semibold mb-4">Pro Plan</h2>
        <p class="text-gray-400 text-sm mb-6">
          Unlock unlimited PDF extractions, advanced table parsing, and priority vector search queries.
        </p>

        <div class="bg-[#0B1120] rounded-xl p-4 border border-gray-800 mb-6 flex justify-between items-center">
          <div>
            <div class="text-2xl font-bold text-white">$29<span class="text-sm text-gray-500 font-normal">/month</span></div>
            <div class="text-xs text-green-400 mt-1">&check; Includes all AI modules</div>
          </div>
          <button class="bg-white text-black px-6 py-2 rounded-lg font-semibold hover:bg-gray-200 transition-colors">
            Upgrade to Pro
          </button>
        </div>

        <div class="border-t border-gray-800 pt-6">
          <h3 class="text-sm font-medium text-white mb-2">Payment Methods</h3>
          <p class="text-xs text-gray-500 mb-4">Manage your credit cards and billing history via the secure Stripe portal.</p>
          <button class="text-sm text-blue-400 hover:text-blue-300 font-medium">
            Open Billing Portal &rarr;
          </button>
        </div>
      </div>

    </div>
  </div>

</body>
</html>