---
// src/pages/billing.astro
import Layout from '../../layouts/Layout.astro';
import '../../styles/global.css';
---

<html lang="en">
<head>
  <title>Billing & Plans</title>
</head>
<body className="bg-[#0B1120] text-white min-h-screen">
  
  <div className="max-w-5xl mx-auto px-6 py-12">
    <div className="flex justify-between items-center mb-10">
      <h1 className="text-3xl font-bold">Billing & Usage</h1>
      <a href="/dashboard/profile" className="text-sm text-gray-400 hover:text-white">← Back to Profile</a>
    </div>

    <div className="grid grid-cols-1 md:grid-cols-3 gap-6">
      
      {/* Current Usage Card */}
      <div className="col-span-1 bg-[#111827] rounded-2xl p-6 border border-gray-800">
        <h2 className="text-xl font-semibold mb-2">Current Plan</h2>
        <div className="inline-block bg-gray-800 text-gray-300 text-xs px-3 py-1 rounded-full mb-6 font-mono">
          FREE TIER
        </div>
        
        <div className="space-y-4">
          <div>
            <div className="flex justify-between text-sm mb-1">
              <span className="text-gray-400">PDF Extractions</span>
              <span className="text-white font-medium">1 / 3 Daily</span>
            </div>
            <div className="w-full bg-gray-800 rounded-full h-2">
              <div className="bg-blue-500 h-2 rounded-full" style="width: 33%"></div>
            </div>
          </div>
        </div>
      </div>

      {/* Upgrade / Manage Card */}
      <div className="col-span-1 md:col-span-2 bg-[#111827] rounded-2xl p-6 border border-gray-800">
        <h2 className="text-xl font-semibold mb-4">Pro Plan</h2>
        <p className="text-gray-400 text-sm mb-6">
          Unlock unlimited PDF extractions, advanced table parsing, and priority vector search queries.
        </p>

        <div className="bg-[#0B1120] rounded-xl p-4 border border-gray-800 mb-6 flex justify-between items-center">
          <div>
            <div className="text-2xl font-bold text-white">$29<span className="text-sm text-gray-500 font-normal">/month</span></div>
            <div className="text-xs text-green-400 mt-1">✓ Includes all AI modules</div>
          </div>
          {/* Wire this button up to your backend /api/checkout route */}
          <button className="bg-white text-black px-6 py-2 rounded-lg font-semibold hover:bg-gray-200 transition-colors">
            Upgrade to Pro
          </button>
        </div>

        <div className="border-t border-gray-800 pt-6">
          <h3 className="text-sm font-medium text-white mb-2">Payment Methods</h3>
          <p className="text-xs text-gray-500 mb-4">Manage your credit cards and billing history via the secure Stripe portal.</p>
          {/* Wire this to Stripe Customer Portal */}
          <button className="text-sm text-blue-400 hover:text-blue-300 font-medium">
            Open Billing Portal →
          </button>
        </div>
      </div>

    </div>
  </div>

</body>
</html>