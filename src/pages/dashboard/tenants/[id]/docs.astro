---
// 👇 THE FIX: Exactly 4 levels up to reach the 'src' folder, not 5!
import Layout from '../../../../layouts/Layout.astro';
import DocsManager from '../../../../components/DocsManager.jsx';

const user = Astro.locals.user;
const { id } = Astro.params;

// Optional but highly recommended: Kick them out if their session expired
if (!user) {
    return Astro.redirect('/login');
}

// VIP Check: Super Admins get instant true
const ADMIN_EMAILS = ['rajaseg@outlook.com', 'rajaseg@gmail.com', 'itsraj@outlook.com'];
const isSuperAdmin = ADMIN_EMAILS.includes(user.email);

// Extract the new modular permissions from PocketBase
const userModules = user?.active_modules || [];
const planType = user?.plan_type || 'free';
const legacyContext = user?.app_context || '';

// 👇 FIXED: The Ultimate 'isPro' Check mapping to the new schema
const isProUser = isSuperAdmin || 
                  userModules.includes('all-in-one') || 
                  userModules.includes('daas') || 
                  planType === 'all-in-one' || 
                  planType === 'pro' ||
                  user?.plan === 'pro' || // Keeping just in case of old data
                  legacyContext === 'all-in-one' ||
                  legacyContext === 'daas';
---

<Layout title="Docs & AI Manager">
    <main class="p-8 max-w-4xl mx-auto">
        {/* Pass the calculated boolean directly into the React component */}
        <DocsManager 
            client:load 
            tenantId={id} 
            isPro={isProUser} 
        />
    </main>
</Layout>