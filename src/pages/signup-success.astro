---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

const tenantId = Astro.url.searchParams.get('id');
// Retrieve email from URL if you pass it from create-tenant.ts for the "Resend" logic
const email = Astro.url.searchParams.get('email') || ''; 

const displayId = tenantId || 'PENDING_ID';
const widgetUrl = `https://admin.jammetry.com/widget/${displayId}.js`;
---

<Layout title="Verify Your Account">
  <main class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4">
    <div class="max-w-2xl w-full bg-white p-10 rounded-3xl shadow-2xl border border-gray-100 text-center">
      
      <div class="mb-8 inline-flex items-center justify-center w-24 h-24 bg-blue-50 text-blue-500 rounded-full text-5xl shadow-inner">
        📧
      </div>
      
      <h1 class="text-4xl font-black text-gray-900 mb-4 tracking-tight">Check Your Inbox!</h1>
      <p class="text-gray-600 text-lg mb-6 leading-relaxed">
        We've sent a <strong>verification link</strong> to your email. Please click the link to activate your AI Assistant and reveal your installation code.
      </p>

      <!-- RESEND LOGIC UI -->
      <div class="mb-10">
        <button 
          id="resendBtn" 
          data-email={email}
          class="text-blue-600 font-bold hover:underline text-sm"
        >
          Didn't receive an email? Click to resend.
        </button>
        <p id="resendStatus" class="text-xs mt-2 font-medium hidden"></p>
      </div>

      <!-- INSTRUCTIONS (Hiding this visually until they verify is better for UX) -->
      <div class="opacity-50 pointer-events-none filter blur-[2px] bg-gray-900 rounded-2xl p-8 text-left mb-10 border border-gray-800 shadow-2xl">
        <h3 class="text-blue-400 text-xs font-bold uppercase tracking-widest mb-4">
          Step 1: Install the Widget (Available after verification)
        </h3>
        <div class="bg-black/50 p-4 rounded-lg border border-gray-700/50">
          <pre class="text-green-400 font-mono text-sm"><code>&lt;script src="..."&gt;&lt;/script&gt;</code></pre>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <a href="/login" class="bg-blue-600 text-white py-4 rounded-xl font-bold hover:bg-blue-700 transition-all shadow-lg shadow-blue-100">
          Go to Login
        </a>
        <a href="/" class="bg-gray-100 text-gray-700 py-4 rounded-xl font-bold hover:bg-gray-200 transition-all">
          Back to Home
        </a>
      </div>
    </div>
  </main>
</Layout>

<script is:inline>
  const resendBtn = document.getElementById('resendBtn');
  const statusText = document.getElementById('resendStatus');

  resendBtn?.addEventListener('click', async () => {
    const email = resendBtn.getAttribute('data-email');
    if (!email) return alert("Email not found. Please try signing up again.");

    resendBtn.disabled = true;
    resendBtn.innerText = "Sending...";

    try {
      const response = await fetch('/api/resend-verification', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email })
      });

      statusText.classList.remove('hidden', 'text-red-500', 'text-green-500');
      
      if (response.ok) {
        statusText.innerText = "✅ Verification email resent successfully!";
        statusText.classList.add('text-green-500');
      } else {
        statusText.innerText = "❌ Failed to resend. Please wait a moment before trying again.";
        statusText.classList.add('text-red-500');
      }
    } catch (err) {
      statusText.innerText = "❌ Network error occurred.";
      statusText.classList.add('text-red-500');
    } finally {
      resendBtn.disabled = false;
      resendBtn.innerText = "Resend Verification Email";
    }
  });
</script>