---
import Layout from '../../layouts/Layout.astro';
import nodemailer from 'nodemailer';
import PocketBase from 'pocketbase';

const pb = Astro.locals.pb;
const user = Astro.locals.user;

const ADMIN_EMAILS = ['rajaseg@outlook.com'];
if (!user || !ADMIN_EMAILS.includes(user.email)) {
    return Astro.redirect('/dashboard/tenants'); 
}

let status = '';
let recipientCount = 0;
let errorMessage = '';

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const subject = data.get('subject')?.toString();
    const body = data.get('message')?.toString();

    if (!subject || !body) {
        throw new Error("Subject and Message are required.");
    }

    const pbAdmin = new PocketBase(process.env.PB_URL || "http://rag-pb:8080");
    const adminEmail = process.env.PB_ADMIN_EMAIL;
    const adminPass = process.env.PB_ADMIN_PASSWORD;

    if (adminEmail && adminPass) {
        await pbAdmin.collection('_superusers').authWithPassword(adminEmail, adminPass);
    } else {
        throw new Error("Super Admin credentials missing from .env");
    }

    const usersList = await pbAdmin.collection('users').getFullList({
        fields: 'email' 
    });
    
    const emailList = usersList.map(u => u.email).filter(Boolean);
    recipientCount = emailList.length;

    if (recipientCount === 0) {
        throw new Error("No registered users found to email.");
    }

    if (!process.env.SMTP_USER || !process.env.SMTP_PASS) {
        throw new Error("SMTP credentials missing from .env. Cannot send emails.");
    }

    const transporter = nodemailer.createTransport({
        host: process.env.SMTP_HOST || 'smtp.gmail.com',
        port: parseInt(process.env.SMTP_PORT || '465'),
        secure: true, 
        auth: {
            user: process.env.SMTP_USER,
            pass: process.env.SMTP_PASS
        }
    });

    await transporter.sendMail({
        from: `"Jammetry AI" <${process.env.SMTP_USER}>`,
        bcc: emailList, 
        subject: subject,
        html: `
        <div style="background-color: #f3f4f6; padding: 40px 20px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
            <div style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 12px; overflow: hidden; border: 1px solid #e5e7eb; box-shadow: 0 4px 6px rgba(0, 0, 0, 0.05);">
                
                <div style="background-color: #2563eb; padding: 24px; text-align: center;">
                    <h2 style="color: #ffffff; margin: 0; font-size: 24px; font-weight: 800; letter-spacing: -0.5px;">Jammetry AI</h2>
                </div>
                
                <div style="padding: 32px 32px; color: #374151; font-size: 16px; line-height: 1.7;">
                    ${body.replace(/\n/g, '<br>')}
                </div>
                
                <div style="background-color: #f9fafb; padding: 24px; text-align: center; border-top: 1px solid #e5e7eb;">
                    <p style="margin: 0; font-size: 13px; color: #6b7280; font-weight: 600;">Jammetry AI Platform</p>
                    <p style="margin: 6px 0 0 0; font-size: 12px; color: #9ca3af;">You are receiving this service update because you are a registered user.</p>
                </div>
                
            </div>
        </div>`
    });
    
    status = 'success';
  } catch (e: any) {
    status = 'error';
    errorMessage = e.message || "An error occurred while sending the broadcast.";
    console.error("[BROADCAST ERROR]", e.message);
  }
}
---

<Layout title="Email Broadcast | Admin">
  <main class="p-8 max-w-4xl mx-auto relative">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900">Email Broadcast</h1>
      <p class="text-gray-500">Send an update to all registered users on the platform.</p>
    </div>

    {status === 'success' && (
      <div class="bg-green-50 border border-green-200 text-green-800 px-6 py-4 rounded-xl mb-8 flex items-center gap-3 shadow-sm">
        <span class="text-2xl">🚀</span>
        <div>
            <strong class="block">Broadcast Complete!</strong>
            <span class="text-sm">Successfully sent message to {recipientCount} users via BCC.</span>
        </div>
      </div>
    )}

    {status === 'error' && (
      <div class="bg-red-50 border border-red-200 text-red-800 px-6 py-4 rounded-xl mb-8 flex items-center gap-3 shadow-sm">
        <svg class="w-6 h-6 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <div>
            <strong class="block">Broadcast Failed</strong>
            <span class="text-sm">{errorMessage}</span>
        </div>
      </div>
    )}

    <div class="bg-white p-8 rounded-2xl shadow-sm border border-gray-100 relative">
      <form id="broadcastForm" method="POST" class="space-y-6">
        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2">Subject Line</label>
          <input 
            type="text" 
            name="subject" 
            required 
            class="w-full px-4 py-3 rounded-lg border border-gray-300 outline-none focus:ring-2 focus:ring-blue-500 transition-shadow"
            placeholder="e.g. New Feature: Website Crawling is now live!"
          />
        </div>

        <div>
          <label class="block text-sm font-bold text-gray-700 mb-2 flex justify-between">
            <span>Message Content</span>
            <span class="text-gray-400 font-normal text-xs">HTML Supported</span>
          </label>
          <textarea 
            name="message" 
            required 
            rows="10" 
            class="w-full px-4 py-3 rounded-lg border border-gray-300 outline-none focus:ring-2 focus:ring-blue-500 font-mono text-sm transition-shadow resize-y"
            placeholder="Write your announcement here..."
          ></textarea>
        </div>

        <div class="pt-4 border-t border-gray-100">
          <button 
            type="button" 
            id="triggerModalBtn"
            class="w-full bg-blue-600 text-white font-bold py-4 rounded-xl hover:bg-blue-700 transition-all shadow-md hover:shadow-lg flex justify-center items-center gap-2"
          >
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"></path></svg>
            Review & Send Broadcast
          </button>
        </div>
      </form>
    </div>

    {/* Custom Confirmation Modal */}
    <div id="confirmModal" class="fixed inset-0 bg-gray-900 bg-opacity-50 z-50 hidden flex items-center justify-center backdrop-blur-sm transition-opacity">
        <div class="bg-white rounded-2xl shadow-2xl p-8 max-w-md w-full mx-4 transform scale-100 transition-transform">
            <div class="flex items-center justify-center w-12 h-12 rounded-full bg-blue-100 text-blue-600 mb-6 mx-auto">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 19v-8.93a2 2 0 01.89-1.664l7-4.666a2 2 0 012.22 0l7 4.666A2 2 0 0121 10.07V19M3 19a2 2 0 002 2h14a2 2 0 002-2M3 19l6.75-4.5M21 19l-6.75-4.5M3 10l6.75 4.5M21 10l-6.75 4.5m0 0l-1.14.76a2 2 0 01-2.22 0l-1.14-.76"></path></svg>
            </div>
            <h3 class="text-2xl font-bold text-center text-gray-900 mb-2">Send Broadcast?</h3>
            <p class="text-center text-gray-500 mb-8">This will send an email to all registered users. Are you sure you want to proceed? This action cannot be undone.</p>
            
            <div class="flex gap-4">
                <button id="cancelBtn" class="flex-1 px-4 py-3 rounded-xl border border-gray-300 text-gray-700 font-bold hover:bg-gray-50 transition-colors">
                    Cancel
                </button>
                <button id="confirmBtn" class="flex-1 px-4 py-3 rounded-xl bg-blue-600 text-white font-bold hover:bg-blue-700 transition-colors flex justify-center items-center gap-2">
                    Send Now
                </button>
            </div>
        </div>
    </div>

  </main>
</Layout>

<script is:inline>
    const form = document.getElementById('broadcastForm');
    const triggerBtn = document.getElementById('triggerModalBtn');
    const modal = document.getElementById('confirmModal');
    const cancelBtn = document.getElementById('cancelBtn');
    const confirmBtn = document.getElementById('confirmBtn');

    // Show modal only if form is valid
    triggerBtn.addEventListener('click', () => {
        if (form.checkValidity()) {
            modal.classList.remove('hidden');
        } else {
            form.reportValidity(); // Shows default "Please fill out this field" tooltips
        }
    });

    // Hide modal on cancel
    cancelBtn.addEventListener('click', (e) => {
        e.preventDefault();
        modal.classList.add('hidden');
    });

    // Submit form and show loading state
    confirmBtn.addEventListener('click', (e) => {
        e.preventDefault();
        confirmBtn.innerHTML = '<svg class="animate-spin h-5 w-5 mr-2 text-white" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4" fill="none"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path></svg> Sending...';
        confirmBtn.classList.add('opacity-80', 'cursor-not-allowed');
        cancelBtn.disabled = true;
        form.submit();
    });
</script>