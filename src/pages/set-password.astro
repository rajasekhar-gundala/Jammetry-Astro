---
import Layout from '../layouts/Layout.astro';
import PocketBase from 'pocketbase';
import '../styles/global.css';

// 1. Grab the token from the URL (e.g., ?token=xyz123)
const token = Astro.url.searchParams.get('token');
let errorMessage = '';

// Prevent users from accessing this page without a token
if (!token && Astro.request.method === 'GET') {
  return Astro.redirect('/login?error=missing-token');
}

// 2. Handle the Form Submission
if (Astro.request.method === 'POST') {
  const pb = new PocketBase("http://pocketbase:8080"); // Use your PB URL
  
  try {
    const data = await Astro.request.formData();
    const submittedToken = data.get('token')?.toString();
    const password = data.get('password')?.toString();
    const passwordConfirm = data.get('passwordConfirm')?.toString();

    // Basic Validation
    if (!password || password.length < 8) {
      errorMessage = "Password must be at least 8 characters long.";
    } else if (password !== passwordConfirm) {
      errorMessage = "Passwords do not match.";
    } else if (submittedToken) {
      // Send the confirmation to PocketBase
      await pb.collection('users').confirmPasswordReset(submittedToken, password, passwordConfirm);
      
      // Success! Redirect them to the login page so they can enter their new credentials
      return Astro.redirect('/login?message=password-set');
    }
  } catch (e: any) {
    console.error("Password reset error:", e?.response?.data || e.message);
    errorMessage = "Failed to set password. Your link may have expired or already been used.";
  }
}
---

<Layout title="Set Your Password - Jammetry AI" hideNav={true}>
  <main class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4">
    <div class="max-w-md w-full">
      
      <div class="flex justify-center mb-8">
        <a href="/" class="flex items-center gap-2">
          <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          <span class="text-2xl font-bold tracking-tight text-gray-900">Jammetry AI</span>
        </a>
      </div>

      <div class="bg-white p-10 rounded-2xl shadow-xl border border-gray-100">
        <div class="text-center mb-8">
          <h2 class="text-3xl font-extrabold text-gray-900">Set Your Password</h2>
          <p class="mt-2 text-sm text-gray-600">Secure your account to access your dashboard.</p>
        </div>
        
        {errorMessage && (
          <div class="mb-6 bg-red-50 text-red-700 p-4 rounded-lg text-sm border border-red-100">
            {errorMessage}
          </div>
        )}

        <form method="POST" class="space-y-6">
          <!-- Hidden input to pass the token to the POST request -->
          <input type="hidden" name="token" value={token} />

          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">New Password</label>
              <input name="password" type="password" required minlength="8" class="w-full px-3 py-3 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" placeholder="••••••••">
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Confirm Password</label>
              <input name="passwordConfirm" type="password" required minlength="8" class="w-full px-3 py-3 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" placeholder="••••••••">
            </div>
          </div>

          <button type="submit" class="w-full flex justify-center py-3 px-4 text-sm font-bold rounded-lg text-white bg-blue-600 hover:bg-blue-700 transition-all shadow-lg shadow-blue-100">
            Save Password & Continue
          </button>
        </form>
        
      </div>
    </div>
  </main>
</Layout>