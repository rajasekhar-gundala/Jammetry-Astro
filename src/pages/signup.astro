---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="Sign Up - Start Your AI Assistant" hideNav={true}>
  <main class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4">
    <div class="max-w-md w-full">
      <div class="flex justify-center mb-8">
        <a href="/" class="flex items-center gap-2">
          <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
          <span class="text-2xl font-bold tracking-tight text-gray-900">Jammetry AI</span>
        </a>
      </div>

      <div class="bg-white p-10 rounded-2xl shadow-xl border border-gray-100">
        <div class="text-center mb-8">
          <h2 class="text-3xl font-extrabold text-gray-900">Start Your 14-Day Trial</h2>
          <p class="mt-2 text-sm text-gray-600">Get your first 100 chats free.</p>
        </div>
        
        <form class="space-y-6">
          
          {/* 👉 NEW: The Error Banner (Hidden by default) */}
          <div id="error-message" class="hidden bg-red-50 text-red-700 p-4 rounded-lg text-sm border border-red-200 flex items-start gap-2">
            <svg class="w-5 h-5 shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
            <span id="error-text"></span>
          </div>

          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Company Name</label>
              <input 
                name="name" 
                type="text" 
                required 
                minlength="2"
                pattern=".*[a-zA-Z0-9].*"
                title="Please enter a valid company name."
                class="w-full px-3 py-3 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" 
                placeholder="Acme Corp"
              >
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Work Email</label>
              <input 
                name="email" 
                type="email" 
                required 
                class="w-full px-3 py-3 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" 
                placeholder="john@company.com"
              >
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Website URL</label>
              <input 
                name="domain" 
                type="text" 
                required 
                pattern="^(https?:\/\/)?([\w-]+\.)+[\w-]{2,}(\/.*)?$"
                title="Please enter a valid website URL (e.g., example.com or https://example.com)"
                class="w-full px-3 py-3 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500" 
                placeholder="www.example.com"
              >
            </div>
          </div>

          <button type="submit" class="w-full flex justify-center py-3 px-4 text-sm font-bold rounded-lg text-white bg-blue-600 hover:bg-blue-700 transition-all shadow-lg shadow-blue-100">
            Create My AI Assistant
          </button>
        </form>
        
        <p class="text-center text-xs text-gray-500 mt-6">By signing up, you agree to our Terms of Service.</p>
      </div>
    </div>
  </main>
</Layout>

<script>
  const form = document.querySelector('form');
  const errorBox = document.getElementById('error-message');
  const errorText = document.getElementById('error-text');
  
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    
    // Hide previous errors on new submission
    if(errorBox) errorBox.classList.add('hidden');
    
    const submitBtn = form.querySelector('button[type="submit"]');
    if (submitBtn) {
      submitBtn.disabled = true;
      submitBtn.innerText = "Setting up your account...";
    }

    const formData = new FormData(form as HTMLFormElement);

    let domainValue = formData.get('domain')?.toString().trim();
    if (domainValue && !/^https?:\/\//i.test(domainValue)) {
        domainValue = 'https://' + domainValue;
        formData.set('domain', domainValue);
    }

    try {
      const response = await fetch('/api/create-tenant', {
        method: 'POST',
        body: formData 
      });

      const result = await response.json();

      if (response.ok) {
        window.location.href = result.redirectUrl;
      } else {
        // 👉 NEW: Display the error beautifully in the UI
        if(errorBox && errorText) {
            errorText.innerText = result.error || "Signup failed. Please try again.";
            errorBox.classList.remove('hidden');
        }
      }
    } catch (err) {
      console.error("Signup error:", err);
      if(errorBox && errorText) {
          errorText.innerText = "A network error occurred. Please check your connection.";
          errorBox.classList.remove('hidden');
      }
    } finally {
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerText = "Create My AI Assistant";
      }
    }
  });
</script>