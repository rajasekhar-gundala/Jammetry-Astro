---
import Layout from '../layouts/Layout.astro';
import PocketBase from 'pocketbase';
import '../styles/global.css';

let message = '';
let isError = false;

if (Astro.request.method === 'POST') {
  try {
    const data = await Astro.request.formData();
    const email = data.get('email')?.toString().trim();

    if (email) {
      const pb = new PocketBase("http://pocketbase:8080");
      
      // Request the reset email from PocketBase
      await pb.collection('users').requestPasswordReset(email);

      // Show success message
      message = "If an account exists with that email, we've sent password reset instructions.";
      isError = false;
    } else {
      message = "Please enter a valid email address.";
      isError = true;
    }
  } catch (e: any) {
    console.error("[PASSWORD RESET REQUEST ERROR]", e.response?.message || e.message);
    
    // Security best practice: Still show the success message so attackers can't guess valid emails
    message = "If an account exists with that email, we've sent password reset instructions.";
    isError = false;
  }
}
---

<Layout title="Forgot Password - Jammetry AI" hideNav={true}>
  <main class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4">
    <div class="max-w-md w-full">
      
      <div class="flex justify-center mb-8">
        <a href="/" class="flex items-center gap-2">
          <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
          </svg>
          <span class="text-2xl font-bold tracking-tight text-gray-900">Jammetry AI</span>
        </a>
      </div>

      <div class="bg-white p-10 rounded-2xl shadow-xl border border-gray-100">
        <div class="text-center mb-8">
          <h2 class="text-3xl font-extrabold text-gray-900">Reset Password</h2>
          <p class="mt-2 text-sm text-gray-600">Enter your email and we'll send you a reset link.</p>
        </div>
        
        {message && (
          <div class={`mb-6 p-4 rounded-lg text-sm border text-center font-medium ${isError ? 'bg-red-50 text-red-700 border-red-100' : 'bg-green-50 text-green-700 border-green-100'}`}>
            {message}
          </div>
        )}

        {!message || isError ? (
          <form method="POST" class="space-y-6">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Email Address</label>
              <input name="email" type="email" required class="w-full px-4 py-3 border border-gray-300 rounded-lg focus:ring-blue-500 focus:border-blue-500 outline-none transition-all" placeholder="admin@jammetry.com">
            </div>

            <button type="submit" class="w-full flex justify-center py-3 px-4 text-sm font-bold rounded-lg text-white bg-blue-600 hover:bg-blue-700 transition-all shadow-lg shadow-blue-100">
              Send Reset Link
            </button>
          </form>
        ) : (
           <div class="text-center mt-6">
              <a href="/login" class="inline-flex justify-center py-3 px-4 text-sm font-bold rounded-lg text-blue-600 bg-blue-50 hover:bg-blue-100 transition-all w-full">
                Return to Login
              </a>
           </div>
        )}
        
        <!-- Only show the back link if the form hasn't been successfully submitted yet -->
        {(!message || isError) && (
          <div class="text-center mt-6">
            <a href="/login" class="text-sm font-medium text-gray-500 hover:text-gray-900 transition-colors">
              &larr; Back to login
            </a>
          </div>
        )}
      </div>
    </div>
  </main>
</Layout>