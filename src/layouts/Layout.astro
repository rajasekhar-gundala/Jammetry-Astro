---
import '../styles/global.css';

interface Props {
  title: string;
  hideNav?: boolean; 
}

const { title, hideNav = false } = Astro.props;
const user = Astro.locals.user;

const ADMIN_EMAILS = ['rajaseg@outlook.com', 'rajaseg@gmail.com']; 
const isSuperAdmin = user && ADMIN_EMAILS.includes(user?.email);

// Get active modules, fallback to legacy app_context for smooth transition
let userModules = user?.active_modules || [];
const legacyContext = user?.app_context || '';
if (legacyContext === 'all-in-one') userModules = ['chat', 'extract', 'daas', 'knowledgebase', 'hosting'];
if (legacyContext === 'jammetry') userModules = [...userModules, 'chat'];
if (legacyContext === 'daas') userModules = [...userModules, 'daas', 'knowledgebase'];

const pathname = Astro.url.pathname;
const isDashboardArea = pathname.startsWith('/dashboard');
const isAdminArea = pathname.startsWith('/admin') && isSuperAdmin;
const isPublicArea = !isDashboardArea && !isAdminArea;
const { id } = Astro.params;

const showNav = !hideNav;

const getLinkStyle = (path: string, exact = false, isFallback = false) => {
    // If it's a fallback route (like Docs & AI without a tenant), don't show it as active
    if (isFallback) return "flex items-center gap-1.5 text-sm font-medium text-gray-600 hover:text-blue-600 hover:bg-gray-50 px-3 py-2 rounded-lg transition-colors";
    
    const isActive = exact ? pathname === path : pathname.startsWith(path);
    return isActive 
        ? "flex items-center gap-1.5 text-sm font-bold text-blue-700 bg-blue-50 px-3 py-2 rounded-lg" 
        : "flex items-center gap-1.5 text-sm font-medium text-gray-600 hover:text-blue-600 hover:bg-gray-50 px-3 py-2 rounded-lg transition-colors";
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} | Jammetry AI</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="antialiased text-gray-900 bg-white">
    
    {showNav && (
      <nav class="bg-white border-b border-gray-200 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
          <div class="flex justify-between h-16">
            <div class="flex items-center gap-8">
              
              <a href={isAdminArea ? "/admin/inquiries" : isDashboardArea ? "/dashboard/tenants" : "/"} class="flex items-center gap-2">
                <span class="text-xl font-bold text-blue-600">
                    {isAdminArea ? "Super Admin" : "Jammetry AI"}
                </span>
              </a>

              <div class="hidden md:flex gap-1 items-center">
                
                {/* 1. PUBLIC MENU */}
                {isPublicArea && (
                    <>
                        <a href="/" class={getLinkStyle('/', true)}>Home</a>
                        <a href="/contact" class={getLinkStyle('/contact')}>Contact Us</a>
                    </>
                )}

                {/* 2. CUSTOMER MENU */}
                {isDashboardArea && (
    <>
        {/* Knowledgebase/DaaS Apps */}
        {[
            { name: 'Tenants', path: '/dashboard/tenants', moduleId: 'knowledgebase' },
            { name: 'Analytics', path: '/dashboard/analytics', moduleId: 'knowledgebase' },
            { name: 'Leads', path: '/dashboard/leads', moduleId: 'knowledgebase' },
            { name: 'Docs & AI', path: id ? `/dashboard/tenants/${id}/docs` : '/dashboard/tenants', moduleId: 'daas' },
            { name: 'Doc Chat', path: '/dashboard/chat', moduleId: 'chat' },
            { name: 'PDF Extract', path: '/dashboard/extract', moduleId: 'extract' },
        ].map(app => {
            // Check if they have access to this specific module OR if they have the all-in-one pass
            const hasAccess = isSuperAdmin || userModules.includes(app.moduleId) || userModules.includes('all-in-one');
            
            if (!hasAccess) {
                return (
                    <span class="flex items-center gap-1.5 text-sm font-medium text-gray-400 opacity-60 cursor-not-allowed px-3 py-2 rounded-lg bg-gray-50/50 select-none">
                        {app.name}
                        <svg class="w-3.5 h-3.5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"></path></svg>
                    </span>
                );
            }

            return (
                <a href={app.path} class={getLinkStyle(app.path, true)}>
                    {app.name}
                </a>
            )
        })}
    </>
)}

                {/* 3. GOD MODE MENU */}
                {isAdminArea && (
                    <>
                        <a href="/admin/inquiries" class={getLinkStyle('/admin/inquiries')}>Inquiries</a>
                        <a href="/admin/broadcast" class={getLinkStyle('/admin/broadcast')}>Broadcast</a>
                        <a href="/admin/users" class={getLinkStyle('/admin/users')}>Users</a>
                    </>
                )}

              </div>
            </div>
            
            <div class="flex items-center gap-4">
              {user ? (
                  <>
                      <span class="text-xs text-gray-400 hidden sm:block">{user.email}</span>
                      
                      {isSuperAdmin && (
                          isAdminArea ? (
                              <a href="/dashboard/tenants" class="text-xs font-bold text-gray-500 hover:text-gray-900">Go to Dashboard</a>
                          ) : (
                              <a href="/admin/inquiries" class="text-xs font-bold text-gray-500 hover:text-gray-900">Admin Area</a>
                          )
                      )}

                      {/* 👉 THE GLOBAL UPGRADE BUTTON */}
            {!userModules.includes('all-in-one') && (
                <a href="/pricing" class="hidden sm:flex items-center gap-1 text-xs font-bold text-amber-700 bg-amber-100 border border-amber-200 px-3 py-1.5 rounded-md hover:bg-amber-200 transition-colors">
                    <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path></svg>
                    Upgrade Plan
                </a>
            )}

                      <a href="/logout" class="text-xs font-bold text-red-600 bg-red-50 px-3 py-1 rounded-md hover:bg-red-100 transition-colors">Logout</a>
                  </>
              ) : (
                  <>
                      <a href="/login" class="text-sm font-bold text-blue-600 hover:text-blue-700">Log in</a>
                      <a href="/signup" class="text-sm font-bold text-white bg-blue-600 px-4 py-2 rounded-lg hover:bg-blue-700 transition-colors shadow-sm">Start Free Trial</a>
                  </>
              )}
            </div>
          </div>
        </div>
      </nav>
    )}

    <slot />

    {showNav && (
      <footer class="mt-20 py-10 border-t border-gray-50 text-center text-xs text-gray-400">
        &copy; {new Date().getFullYear()} Jammetry AI. Running on 2 vCPU / 8GB RAM Cluster.
      </footer>
    )}
  </body>
</html>